---
// Hero-заголовок главной страницы: выводит локализованные строки с визуальной глубиной.
import { getLocaleFromUrl, useTranslations } from "@/i18n";

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<h1 class="relative select-none overflow-hidden">
<div
  class="absolute bg-linear-to-br z-50 from-background/10 to-transparent dark:from-background/10 dark:to-transparent w-full h-full pointer-events-none"
>
</div>
<div
  class="flex flex-col *:tracking-tight *:md:tracking-[-3.8px] *:font-bold *:text-4xl *:sm:text-5xl *:md:text-6xl *:lg:text-7xl *:uppercase"
>
  <span class="text-depth-100 blur-[3px]">{t("home.hero.1")}</span>
  <span class="text-depth-200 blur-[2px]">{t("home.hero.2")}</span>
  <span class="text-depth-300 blur-[1.5px]">{t("home.hero.3")}</span>
  <span class="text-depth-400 blur-[1px]">{t("home.hero.4")}</span>
		<div class="space-x-3">
			<span class="text-depth-500 blur-[0.5px]">{t("home.hero.5")}</span><span
				class="text-depth-600 blur-[0.4px]">{t("home.hero.6")}</span
			>
			<span class="text-depth-700 blur-[0.3px]">{t("home.hero.7")}</span>
		</div>
	</div>
</h1>
