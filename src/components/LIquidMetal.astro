---
import { LiquidMetal } from "@paper-design/shaders-react";
---

<div
	aria-hidden="true"
	class="pointer-events-none -mb-0 w-[140px] grid place-items-center h-full mx-auto overflow-hidden"
>
	<LiquidMetal
		client:load
		width={140}
		height={140}
		image="/flower.svg"
		colorBack="#ffffff"
		colorTint="#8ccaff"
		shape={undefined}
		repetition={2}
		softness={0.1}
		shiftRed={0.3}
		shiftBlue={0.3}
		distortion={0.07}
		contour={0.4}
		angle={70}
		speed={1}
		scale={0.6}
		fit="contain"
	/>
</div>
