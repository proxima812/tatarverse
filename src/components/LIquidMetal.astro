---
import { LiquidMetal } from "@paper-design/shaders-react";
---

<div
	aria-hidden="true"
	class="liquid-metal pointer-events-none -mb-0 relative grid h-[140px] w-[140px] place-items-center overflow-hidden mx-auto"
>
	<img
		src="/flower.svg"
		alt="Логотип Tatarverse"
		loading="eager"
		class="flower-fade absolute z-50 h-[84px] w-[84px] object-contain"
	/>
	<LiquidMetal
		client:load
		width={140}
		height={140}
		image="/flower.svg"
		colorBack="#ffffff"
		colorTint="#4DDB3E"
		shape={undefined}
		repetition={2}
		softness={0.1}
		shiftRed={0.3}
		shiftBlue={0.3}
		distortion={0.07}
		contour={0.4}
		angle={70}
		speed={0.6}
		scale={0.6}
		fit="contain"
	/>
</div>

<style>
	.flower-fade {
		animation: flower-fade-out 600ms ease-out 1s forwards;
	}

	@keyframes flower-fade-out {
		to {
			opacity: 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.flower-fade {
			animation: none;
		}
	}
</style>

