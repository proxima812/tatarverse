---
import ButtonLink from "@/components/ui/ButtonLink.astro";
import { links } from "@/data/links";

const menuLinks = links.slice(2, 5);
---

<nav class="hidden space-x-3 sm:flex">
	{
		menuLinks.map((item) => (
			<ButtonLink
				variant="ghost"
				icon={item.icon}
				href={item.href}
				label={item.label}
				labelKey={item.labelKey}
			/>
		))
	}
</nav>

<div data-menu class="sm:hidden">
	<button
		type="button"
		data-menu-toggle
		class="fixed top-5 left-5 z-50 grid size-7 cursor-pointer place-items-center rounded-2xl corner-squircle bg-background/70 text-foreground shadow-2xs ring-1 ring-border-muted backdrop-blur-md transition hover:bg-muted focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
		aria-label="Open menu"
		aria-controls="mobile-menu"
		aria-expanded="false"
	>
		<svg
			width="15"
			height="12"
			viewBox="0 0 15 12"
			class="stroke-current"
			stroke-width="1.5"
			stroke-linecap="round"
			aria-hidden="true"
		>
			<line
				x1="0"
				y1="6"
				x2="15"
				y2="6"
				class="-translate-y-0.75"
				style="transform-box: view-box; transform-origin: center center;"></line>
			<line
				x1="0"
				y1="6"
				x2="15"
				y2="6"
				class="translate-y-0.75"
				style="transform-box: view-box; transform-origin: center center;"></line>
		</svg></button
	>

	<nav
		id="mobile-menu"
		data-menu-list
		class="pointer-events-none fixed inset-0 z-40 flex min-h-dvh flex-col gap-2 bg-background/60 px-5 pt-20 opacity-0 backdrop-blur-lg transition-opacity duration-300 ease-out"
		aria-label="Mobile menu"
	>
		{
			links.map((item) => (
				<ButtonLink
					class="w-full justify-start text-lg"
					variant="ghost"
					icon={item.icon}
					href={item.href}
					label={item.label}
					labelKey={item.labelKey}
				/>
			))
		}
	</nav>
</div>

<script>
	document.querySelectorAll<HTMLElement>("[data-menu]").forEach((root) => {
		const toggle = root.querySelector<HTMLButtonElement>("[data-menu-toggle]");
		const list = root.querySelector<HTMLElement>("[data-menu-list]");

		if (!toggle || !list) return;

		const setOpen = (isOpen: boolean) => {
			toggle.setAttribute("aria-expanded", String(isOpen));
			list.classList.toggle("opacity-100", isOpen);
			list.classList.toggle("pointer-events-auto", isOpen);
			list.classList.toggle("pointer-events-none", !isOpen);
		};

		toggle.addEventListener("click", () => {
			setOpen(toggle.getAttribute("aria-expanded") !== "true");
		});

		list.addEventListener("click", (event) => {
			if (event.target instanceof Element && event.target.closest("a")) {
				setOpen(false);
			}
		});

		document.addEventListener("keydown", (event) => {
			if (event.key === "Escape") setOpen(false);
		});
	});
</script>
