---
import { getLocaleFromUrl, useTranslations } from "@/i18n";
import { CENTER_KIND_ICONS, type CenterKindBucket } from "@/utils/centerKinds";
import { Icon } from "astro-icon/components";

interface Props {
	count: number;
	countries: number;
	regions: number;
	/** Optional kind composition. When present, tiles are merged into one grid. */
	buckets?: CenterKindBucket[];
	class?: string;
}

const { count, countries, regions, buckets, class: className } = Astro.props as Props;
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const hasBuckets = Boolean(buckets?.length);

const items = [
	{
		icon: "mdi:map-marker-radius",
		label: hasBuckets ? t("list.stat.total") : t("list.stat.centers"),
		value: count,
	},
	{ icon: "mdi:earth", label: t("list.stat.countries"), value: countries },
	{ icon: "mdi:map-outline", label: t("list.stat.regions"), value: regions },
	...(buckets ?? []).map((bucket) => ({
		icon: CENTER_KIND_ICONS[bucket.kind],
		label: t(`kind.${bucket.kind}`),
		value: bucket.count,
	})),
];

const gridClass = hasBuckets
	? "grid w-full max-w-3xl grid-cols-2 gap-2 sm:grid-cols-3"
	: "grid w-full max-w-md grid-cols-3 gap-2";
---

<dl class:list={["stats-focus", gridClass, className]}>
	{
		items.map((item, index) => (
			<div class:list={["stats-focus__item flex items-center gap-1.5 rounded-2xl corner-squircle bg-surface px-2.5 py-2 ring ring-depth-100/60", hasBuckets ? "justify-start" : "justify-center"]} style={`--i: ${index}`}>
				<Icon name={item.icon} class="stats-focus__icon size-4 shrink-0 text-muted-foreground" aria-hidden="true" />
				<dd class="text-base font-semibold tracking-tight tabular-nums text-foreground sm:text-lg">
					<span class="stats-focus__number" style={`--target: ${item.value}; --i: ${index}`} aria-hidden="true" />
					<span class="sr-only">{item.value}</span>
				</dd>
				<dt class="truncate text-xs font-medium text-muted-foreground">{item.label}</dt>
			</div>
		))
	}
</dl>

<style>
	@property --stat-value {
		syntax: "<integer>";
		inherits: false;
		initial-value: 0;
	}

	.stats-focus {
		--ease: cubic-bezier(0.16, 1, 0.3, 1);
	}

	.stats-focus__item {
		animation: stats-soft-focus 912ms var(--ease) both;
		animation-delay: calc(var(--i) * 120ms);
	}

	.stats-focus__icon {
		animation: stats-icon-mark 620ms var(--ease) both;
		animation-delay: calc(140ms + (var(--i) * 120ms));
	}

	.stats-focus__number {
		--stat-value: 0;
		counter-reset: stat var(--stat-value);
		animation: stats-number 912ms var(--ease) both;
		animation-delay: calc(80ms + (var(--i) * 90ms));
	}

	.stats-focus__number::after {
		content: counter(stat);
	}

	@keyframes stats-number {
		to {
			--stat-value: var(--target);
		}
	}

	@keyframes stats-soft-focus {
		0% {
			opacity: 0.55;
			box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-depth-100) 60%, transparent);
		}
		45% {
			opacity: 1;
			box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-primary) 18%, transparent);
		}
		100% {
			opacity: 1;
			box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-depth-100) 60%, transparent);
		}
	}

	@keyframes stats-icon-mark {
		0% {
			opacity: 0.45;
			transform: scale(0.92);
		}
		100% {
			opacity: 1;
			transform: scale(1);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.stats-focus__item,
		.stats-focus__number,
		.stats-focus__icon {
			--stat-value: var(--target);
			animation-duration: 0.01ms;
			animation-delay: 0ms;
			transform: none;
			filter: none;
		}
	}
</style>
