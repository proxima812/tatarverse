---
import { countryFlagsByRu } from "@/data/worldCountries";
import { getLocaleFromUrl, useTranslations } from "@/i18n";
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";
import BackButton from "../navigation/BackButton.astro";
import NoResults from "../ui/NoResults.astro";
import ActiveFilters from "./ActiveFilters.astro";
import GridCards from "./GridCards.astro";
import Search from "./Search.astro";
import Toolbar from "./Toolbar.astro";

interface Props {
	cards: CollectionEntry<"centers" | "centersEn">[];
	page?: Page<CollectionEntry<"centers" | "centersEn">>;
}

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const { cards, page } = Astro.props as Props;
const countryCounts = new Map<string, number>();
const countryFlags = new Map<string, string>();
for (const card of cards) {
	const country = card.data.location?.country ?? "Прочее";
	const flag = card.data.location?.flag ?? countryFlagsByRu[country];
	countryCounts.set(country, (countryCounts.get(country) ?? 0) + 1);
	if (flag && !countryFlags.has(country)) {
		countryFlags.set(country, flag);
	}
}
const countries = [...countryCounts.entries()].sort((a, b) => b[1] - a[1]);
const regionCounts = new Map<string, number>();
const typeCounts = new Map<string, number>();
const categoryCounts = new Map<string, number>();
for (const card of cards) {
	if (card.data.location?.region) {
		const region = card.data.location.region;
		regionCounts.set(region, (regionCounts.get(region) ?? 0) + 1);
	}

	if (card.data.type) {
		typeCounts.set(card.data.type, (typeCounts.get(card.data.type) ?? 0) + 1);
	}

	if (card.data.category) {
		categoryCounts.set(card.data.category, (categoryCounts.get(card.data.category) ?? 0) + 1);
	}
}
const regions = [...regionCounts.entries()].sort((a, b) => a[0].localeCompare(b[0], "ru"));
const types = [...typeCounts.entries()].sort((a, b) => {
	const order = ["Регион РФ", "Зарубежный", "Онлайн"];
	const leftIndex = order.indexOf(a[0]);
	const rightIndex = order.indexOf(b[0]);
	const safeLeftIndex = leftIndex === -1 ? Number.MAX_SAFE_INTEGER : leftIndex;
	const safeRightIndex = rightIndex === -1 ? Number.MAX_SAFE_INTEGER : rightIndex;

	return safeLeftIndex - safeRightIndex || b[1] - a[1] || a[0].localeCompare(b[0], "ru");
});
const categories = [...categoryCounts.entries()].sort(
	(a, b) => b[1] - a[1] || a[0].localeCompare(b[0], "ru"),
);
const toolbarProps = {
	cardsCount: cards.length,
	countries,
	countryFlags,
	types,
	categories,
	regions,
};
---

<BackButton href="/" label="Назад" labelKey="nav.back" variant="outline" />

<Search />

<ActiveFilters />

<div class="not-container grid grid-cols-1 gap-8 px-5 sm:px-8 lg:grid-cols-[max-content_minmax(0,1fr)] lg:gap-12 lg:px-12">
	<Toolbar {...toolbarProps} />
	<div>
		<NoResults />
		<GridCards cards={cards} />
		{
			page && page.lastPage > 1 && (
				<nav
					class="mt-8 flex flex-wrap items-center justify-between gap-3 border-t border-depth-100 pt-5 text-sm"
					aria-label={t("list.pagination")}
				>
					<a
						href={page.url.prev ?? undefined}
						aria-disabled={!page.url.prev}
						class:list={[
							"inline-flex items-center rounded-2xl px-4 py-2 font-medium ring ring-primary/10 transition",
							page.url.prev
								? "text-primary hover:bg-primary/5"
								: "pointer-events-none text-muted-foreground/50",
						]}
					>
						{t("list.previousPage")}
					</a>
					<span class="text-muted-foreground">
						{t("list.pageStatus", {
							current: page.currentPage,
							total: page.lastPage,
						})}
					</span>
					<a
						href={page.url.next ?? undefined}
						aria-disabled={!page.url.next}
						class:list={[
							"inline-flex items-center rounded-2xl px-4 py-2 font-medium ring ring-primary/10 transition",
							page.url.next
								? "text-primary hover:bg-primary/5"
								: "pointer-events-none text-muted-foreground/50",
						]}
					>
						{t("list.nextPage")}
					</a>
				</nav>
			)
		}
	</div>
</div>
