---
import { getLocaleFromUrl, localizePath, useTranslations } from "@/i18n";
import { Icon } from "astro-icon/components";

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<form
	data-search-form
	data-search-index-url={localizePath(locale, "/centers/search-index.json")}
	data-speech-lang={locale === "en" ? "en-US" : "ru-RU"}
	data-voice-listening={t("list.voiceListening")}
	data-voice-error={t("list.voiceError")}
	role="search"
	class="relative z-40 mb-6 flex items-center gap-1.5 rounded-2xl corner-squircle bg-surface p-2 shadow-2xs ring ring-depth-100 lg:mb-10"
>
	<label class="relative z-50 min-w-0 flex-1" for="centers-search">
		<span class="sr-only">{t("list.search.placeholder")}</span>
		<input
			id="centers-search"
			data-toolbar-search
			type="search"
			placeholder={t("list.search.placeholder")}
			aria-label={t("list.search.placeholder")}
			aria-controls="cards-grid"
			aria-autocomplete="list"
			aria-expanded="false"
			aria-haspopup="listbox"
			aria-owns="search-suggestions"
			autocomplete="off"
			class="min-h-10 w-full bg-transparent px-2 pr-9 text-sm font-medium text-surface-foreground outline-none placeholder:text-depth-500 [&::-webkit-search-cancel-button]:hidden"
		/>
		<button
			type="button"
			data-search-clear
			aria-label={t("list.clearSearch")}
			hidden
			class="absolute right-1 top-1/2 grid size-7 -translate-y-1/2 cursor-pointer place-content-center rounded-full text-subtle-foreground transition hover:bg-muted hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/35"
		>
			<Icon name="mdi:close" class="size-4" aria-hidden="true" />
		</button>
	</label>

	<button
		type="button"
		data-filters-toggle
		aria-label={t("list.filters")}
		aria-expanded="false"
		aria-controls="filters-panel"
		class="relative grid size-10 shrink-0 place-items-center rounded-full bg-muted text-muted-foreground transition hover:bg-subtle focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/35 lg:hidden"
	>
		<Icon name="mdi:tune" class="size-4" aria-hidden="true" />
		<span
			data-filters-badge
			class="absolute -right-1 -top-1 hidden min-w-4 rounded-full bg-primary px-1 text-center text-[10px] font-semibold tabular-nums text-primary-foreground"
		></span>
	</button>

	<button
		type="button"
		data-search-voice
		data-listening="false"
		aria-label={t("list.voiceSearch")}
		aria-pressed="false"
		hidden
		class="grid size-10 shrink-0 place-items-center rounded-full text-muted-foreground transition hover:bg-muted hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/35 data-[listening=true]:bg-primary data-[listening=true]:text-primary-foreground"
	>
		<Icon name="mdi:microphone-outline" class="size-5" aria-hidden="true" />
	</button>

	<button
		type="submit"
		data-search-submit
		aria-label={t("list.submitSearch")}
		disabled
		class="grid size-10 shrink-0 place-items-center rounded-full bg-primary text-primary-foreground transition enabled:cursor-pointer enabled:hover:bg-depth-700 enabled:active:scale-95 disabled:cursor-not-allowed disabled:bg-muted disabled:text-depth-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
	>
		<Icon name="mdi:arrow-up" class="size-5" aria-hidden="true" />
	</button>

	<p data-voice-status class="sr-only" aria-live="polite"></p>

	<ul
		id="search-suggestions"
		data-search-suggestions
		role="listbox"
		class="absolute left-0 right-0 top-[calc(100%+0.5rem)] z-40 hidden max-h-80 overflow-y-auto rounded-2xl corner-squircle bg-surface p-1.5 text-sm shadow-md ring ring-depth-100"
	>
	</ul>
</form>
