---
import { Icon } from "astro-icon/components";
import { getCountryLabels, getCountryLabel } from "@/data/worldCountries";
import { getLocaleFromUrl, useTranslations } from "@/i18n";

interface FilterOption {
	value: string;
	count: number;
}

interface Props {
	cardsCount: number;
	countries: [string, number][];
	countryFlags: Map<string, string>;
	types: [string, number][];
	categories: [string, number][];
	regions: [string, number][];
}

const { cardsCount, countries, countryFlags, types, categories, regions } =
	Astro.props as Props;
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

type CountryLabels = Record<string, string>;

const chipClass =
	"group min-w-0 cursor-pointer items-center gap-1.5 rounded-full border border-transparent bg-transparent px-2.5 py-1.5 text-sm font-medium text-muted-foreground transition hover:border-border hover:bg-muted hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/25 data-[active]:border-primary/20 data-[active]:bg-primary/10 data-[active]:text-primary";
const filterSectionClass =
	"border-b border-depth-100/70 pb-4 last:border-b-0 last:pb-0";
const filterHeadingClass =
	"text-[11px] font-semibold tracking-wide text-subtle-foreground uppercase";
const filterGroupClass = "flex max-w-72 flex-wrap items-center gap-1.5";
const countClass =
	"rounded-full bg-subtle px-1.5 py-0.5 text-[10px] tabular-nums text-subtle-foreground group-data-[active]:bg-primary/10 group-data-[active]:text-primary";
const moreButtonClass =
	"mt-0.5 inline-flex max-w-fit cursor-pointer text-xs font-medium text-muted-foreground underline decoration-border underline-offset-4 transition hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/25";
const countryVisibleLimit = 5;
const defaultVisibleLimit = 2;

function buildCountryLabels(country: string): CountryLabels {
	return getCountryLabels(country);
}

function buildOptions(entries: [string, number][]): FilterOption[] {
	return entries.map(([value, count]) => ({ value, count }));
}

const typeOptions = buildOptions(types);
const categoryOptions = buildOptions(categories);
const regionOptions = buildOptions(regions);

function getVisibleOptions<T>(options: T[], limit = defaultVisibleLimit) {
	return options.slice(0, limit);
}

function getOverflowOptions<T>(options: T[], limit = defaultVisibleLimit) {
	return options.slice(limit);
}
---

<aside
	data-filters-shell
	class="hidden w-fit max-w-72 pb-12 lg:sticky lg:top-12 lg:block lg:max-h-[calc(100vh-3rem)] lg:overflow-y-auto"
>
	<section class="w-fit max-w-72">
		<div id="filters-panel" data-filters-panel class="hidden w-fit max-w-72 space-y-4">
			<section class={filterSectionClass}>
				<p class={filterHeadingClass}>
					{t("list.countries")}
				</p>
				<div
					class={`${filterGroupClass} mt-2`}
					role="group"
					aria-label={t("list.countries.aria")}
					data-filter-group="country"
				>
					<button
						type="button"
						data-filter-all="country"
						data-active=""
						aria-pressed="true"
						class={`inline-flex max-w-fit ${chipClass}`}
					>
						<Icon name="mdi:align-horizontal-left" />
						<span>{t("list.all")}</span>
						<span
							class={countClass}
						>
							{cardsCount}
						</span>
					</button>

					{
						getVisibleOptions(countries, countryVisibleLimit).map(([country, count]) => (
							<button
								type="button"
								data-filter-chip="country"
								data-filter-value={country}
								aria-pressed="false"
								class={`inline-flex max-w-fit ${chipClass}`}
							>
								{countryFlags.get(country) && (
									<span class="text-sm leading-none">{countryFlags.get(country)}</span>
								)}
								<span
									class="min-w-0 truncate"
									data-country-label={country}
									data-country-labels={JSON.stringify(buildCountryLabels(country))}
								>
									{getCountryLabel(country, locale)}
								</span>
								<span class={countClass}>
									{count}
								</span>
							</button>
						))
					}
					{
						getOverflowOptions(countries, countryVisibleLimit).map(([country, count]) => (
							<button
								type="button"
								data-filter-chip="country"
								data-filter-value={country}
								data-overflow-chip="true"
								aria-pressed="false"
								class={`inline-flex max-w-fit ${chipClass}`}
								hidden
							>
								{countryFlags.get(country) && (
									<span class="text-sm leading-none">{countryFlags.get(country)}</span>
								)}
								<span
									class="min-w-0 truncate"
									data-country-label={country}
									data-country-labels={JSON.stringify(buildCountryLabels(country))}
								>
									{getCountryLabel(country, locale)}
								</span>
								<span class={countClass}>
									{count}
								</span>
							</button>
						))
					}
				</div>
				{
					getOverflowOptions(countries, countryVisibleLimit).length > 0 && (
						<button
							type="button"
							class={moreButtonClass}
							data-filter-more="country"
							data-expanded="false"
							data-show-more={t("list.showMore", { count: "__COUNT__" })}
							data-show-less={t("list.showLess")}
						>
							{t("list.showMore", {
								count: getOverflowOptions(countries, countryVisibleLimit).length,
							})}
						</button>
					)
				}
			</section>

			{
				typeOptions.length > 0 && (
					<section class={filterSectionClass}>
						<p class={filterHeadingClass}>
							{t("list.types")}
						</p>
						<div
							class={`${filterGroupClass} mt-2`}
							role="group"
							aria-label={t("list.types.aria")}
							data-filter-group="type"
						>
							<button
								type="button"
								data-filter-all="type"
								data-active=""
								aria-pressed="true"
								class={`inline-flex max-w-fit ${chipClass}`}
							>
								<Icon name="mdi:align-horizontal-left" />
								<span>{t("list.allTypes")}</span>
							</button>

							{getVisibleOptions(typeOptions).map((option) => (
								<button
									type="button"
									data-filter-chip="type"
									data-filter-value={option.value}
									aria-pressed="false"
									class={`inline-flex max-w-fit ${chipClass}`}
								>
									<span class="min-w-0 truncate">{option.value}</span>
									<span class={countClass}>
										{option.count}
									</span>
								</button>
							))}
							{getOverflowOptions(typeOptions).map((option) => (
								<button
									type="button"
									data-filter-chip="type"
									data-filter-value={option.value}
									data-overflow-chip="true"
									aria-pressed="false"
									class={`inline-flex max-w-fit ${chipClass}`}
									hidden
								>
									<span class="min-w-0 truncate">{option.value}</span>
									<span class={countClass}>
										{option.count}
									</span>
								</button>
							))}
						</div>
						{getOverflowOptions(typeOptions).length > 0 && (
							<button
								type="button"
								class={moreButtonClass}
								data-filter-more="type"
								data-expanded="false"
								data-show-more={t("list.showMore", { count: "__COUNT__" })}
								data-show-less={t("list.showLess")}
							>
								{t("list.showMore", { count: getOverflowOptions(typeOptions).length })}
							</button>
						)}
					</section>
				)
			}

			{
				categoryOptions.length > 0 && (
					<section class={filterSectionClass}>
						<p class={filterHeadingClass}>
							{t("list.categories")}
						</p>
						<div
							class={`${filterGroupClass} mt-2`}
							role="group"
							aria-label={t("list.categories.aria")}
							data-filter-group="category"
						>
							<button
								type="button"
								data-filter-all="category"
								data-active=""
								aria-pressed="true"
								class={`inline-flex max-w-fit ${chipClass}`}
							>
								<Icon name="mdi:align-horizontal-left" />
								<span>{t("list.allCategories")}</span>
							</button>

							{getVisibleOptions(categoryOptions).map((option) => (
								<button
									type="button"
									data-filter-chip="category"
									data-filter-value={option.value}
									aria-pressed="false"
									class={`inline-flex max-w-fit ${chipClass}`}
								>
									<span class="min-w-0 truncate">{option.value}</span>
									<span class={countClass}>
										{option.count}
									</span>
								</button>
							))}
							{getOverflowOptions(categoryOptions).map((option) => (
								<button
									type="button"
									data-filter-chip="category"
									data-filter-value={option.value}
									data-overflow-chip="true"
									aria-pressed="false"
									class={`inline-flex max-w-fit ${chipClass}`}
									hidden
								>
									<span class="min-w-0 truncate">{option.value}</span>
									<span class={countClass}>
										{option.count}
									</span>
								</button>
							))}
						</div>
						{getOverflowOptions(categoryOptions).length > 0 && (
							<button
								type="button"
								class={moreButtonClass}
								data-filter-more="category"
								data-expanded="false"
								data-show-more={t("list.showMore", { count: "__COUNT__" })}
								data-show-less={t("list.showLess")}
							>
								{t("list.showMore", { count: getOverflowOptions(categoryOptions).length })}
							</button>
						)}
					</section>
				)
			}

			{
				regionOptions.length > 0 && (
					<section class={filterSectionClass}>
						<p class={filterHeadingClass}>
							{t("list.regions")}
						</p>
						<div
							class={`${filterGroupClass} mt-2`}
							role="group"
							aria-label={t("list.regions.aria")}
							data-filter-group="region"
						>
							<button
								type="button"
								data-filter-all="region"
								data-active=""
								aria-pressed="true"
								class={`inline-flex max-w-fit ${chipClass}`}
							>
								<Icon name="mdi:align-horizontal-left" />
								<span>{t("list.allRegions")}</span>
							</button>

							{getVisibleOptions(regionOptions).map((option) => (
								<button
									type="button"
									data-filter-chip="region"
									data-filter-value={option.value}
									aria-pressed="false"
									class={`inline-flex max-w-fit ${chipClass}`}
								>
									<span class="min-w-0 truncate">{option.value}</span>
									<span class={countClass}>
										{option.count}
									</span>
								</button>
							))}
							{getOverflowOptions(regionOptions).map((option) => (
								<button
									type="button"
									data-filter-chip="region"
									data-filter-value={option.value}
									data-overflow-chip="true"
									aria-pressed="false"
									class={`inline-flex max-w-fit ${chipClass}`}
									hidden
								>
									<span class="min-w-0 truncate">{option.value}</span>
									<span class={countClass}>
										{option.count}
									</span>
								</button>
							))}
						</div>
						{getOverflowOptions(regionOptions).length > 0 && (
							<button
								type="button"
								class={moreButtonClass}
								data-filter-more="region"
								data-expanded="false"
								data-show-more={t("list.showMore", { count: "__COUNT__" })}
								data-show-less={t("list.showLess")}
							>
								{t("list.showMore", { count: getOverflowOptions(regionOptions).length })}
							</button>
						)}
					</section>
				)
			}
		</div>
	</section>
</aside>
<style>
	@media (min-width: 1024px) {
		[data-filters-shell],
		[data-filters-panel] {
			display: block !important;
		}
	}
</style>

<script>
	import { initCardsToolbar } from "@/scripts/centersToolbar";

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initCardsToolbar, { once: true });
	} else {
		initCardsToolbar();
	}
</script>
