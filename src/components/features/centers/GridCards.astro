---
import { createCenterRouteIdMap } from "@/utils/centers";
import type { CollectionEntry } from "astro:content";
import CardItem from "../../ui/card/CardItem.astro";

interface Props {
	cards: CollectionEntry<"centers" | "centersEn">[];
}

const { cards } = Astro.props as Props;
const routeIds = createCenterRouteIdMap(cards);
---

<section
	id="cards-grid"
	class="grid scroll-mt-28 grid-cols-1 gap-6"
>
	{
		cards.map((card) => (
			<CardItem
				id={card.id}
				routeId={routeIds.get(card.id)}
				title={card.data.title}
				summary={card.data.summary}
				type={card.data.type}
				category={card.data.category}
				location={card.data.location}
				region={card.data.location?.region}
				pubDate={card.data.pubDate}
			/>
		))
	}
</section>
