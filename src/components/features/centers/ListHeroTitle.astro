---
// Hero-заголовок страницы списка: крутит названия стран из локализованного словаря.
import { worldCountriesByLocale } from "@/data/worldCountries";
import { getLocaleFromUrl, useTranslations } from "@/i18n";

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const words = worldCountriesByLocale[locale] ?? [];
const initialWord = words[0] ?? "";
const maxWordLength = words.reduce((max, word) => Math.max(max, word.length), 0);
---

<h1
	class="relative select-none overflow-hidden"
	data-list-hero-title
	data-words={JSON.stringify(words)}
>
	<div
		class="absolute bg-linear-to-br z-50 from-background/10 to-transparent dark:from-background/10 dark:to-transparent w-full h-full pointer-events-none"
	>
	</div>
	<div
		class="flex flex-col *:tracking-tight *:md:tracking-[-3.8px] *:font-bold *:text-4xl *:sm:text-5xl *:md:text-6xl *:lg:text-7xl *:uppercase"
	>
		<div class="text-muted-foreground">
			<span class="blur-[0.5px]">
				<span>{t("list.hero.start")}</span>
				<i class="text-3xl sm:text-5xl">&</i>
				<span>{t("list.hero.end")}</span>
			</span>
		</div>
		<span
			class="rotating-word-wrapper inline-block overflow-hidden align-bottom"
			style={`min-inline-size: ${Math.max(8, maxWordLength)}ch;`}
		>
			<span id="rotating-word" class="text-primary tracking-normal font-black inline-block word-rise"
				>{initialWord}</span
			>
		</span>
	</div>
</h1>

<script>
	const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

	document.querySelectorAll<HTMLElement>("[data-list-hero-title]").forEach((root) => {
		const wordElement = root.querySelector<HTMLElement>("#rotating-word");
		const words = JSON.parse(root.dataset.words ?? "[]") as string[];

		if (!wordElement || words.length < 2 || reduceMotion) return;

		let index = 0;
		let timeoutId = 0;

		const rotateWord = () => {
			wordElement.classList.remove("word-rise");
			wordElement.classList.add("word-sink");

			window.setTimeout(() => {
				index = (index + 1) % words.length;
				wordElement.textContent = words[index] ?? "";
				wordElement.classList.remove("word-sink");
				wordElement.classList.add("word-rise");
				timeoutId = window.setTimeout(rotateWord, 1800);
			}, 900);
		};

		timeoutId = window.setTimeout(rotateWord, 1800);

		document.addEventListener(
			"astro:before-swap",
			() => {
				window.clearTimeout(timeoutId);
			},
			{ once: true },
		);
	});
</script>
