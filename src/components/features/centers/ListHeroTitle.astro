---
// Hero-заголовок страницы списка: практичный вводный блок каталога.
import { getLocaleFromUrl, useTranslations } from "@/i18n";

interface Props {
	stats?: {
		count: number;
		countries: number;
		regions: number;
	};
}

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const stats = Astro.props.stats as Props["stats"] | undefined;
const statItems = stats
	? [
			{ label: t("list.stat.centers"), value: stats.count },
			{ label: t("list.stat.countries"), value: stats.countries },
			{ label: t("list.stat.regions"), value: stats.regions },
		]
	: [];
---

<section class="not-container pt-8 pb-10 lg:pt-12">
	<div class="mx-auto max-w-7xl min-w-0 px-6 sm:px-12">
		<div class="mx-auto flex min-w-0 max-w-5xl flex-col items-center space-y-6 text-center">
			<p class="text-sm font-medium text-muted-foreground">{t("list.quickFind")}</p>
			<h1 class="max-w-4xl text-3xl font-bold tracking-[-0.03em] text-foreground sm:text-5xl sm:tracking-[-0.035em] lg:text-6xl">
				{t("list.title")}
			</h1>
			<p class="max-w-3xl text-base leading-7 text-muted-foreground sm:text-lg">
				{t("list.heroIntro")}
			</p>
			{
				statItems.length > 0 && (
					<dl class="flex justify-center flex-wrap gap-2">
						{statItems.map((item) => (
							<div class="flex items-center gap-2 rounded-2xl corner-squircle bg-surface px-3 py-2 shadow-2xs ring ring-depth-100/70">
								<dt class="text-sm text-muted-foreground">{item.label}</dt>
								<dd class="text-sm font-semibold tabular-nums text-foreground">{item.value}</dd>
							</div>
						))}
					</dl>
				)
			}
		</div>
	</div>
</section>
