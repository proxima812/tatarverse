---
import words from "@/assets/images/words.png";
import { Image } from "astro:assets";
---

<section class="w-full h-8 overflow-hidden fade-x">
	<div class="word-marquee-track flex h-full w-max">
		<Image
			src={words}
			alt="Words Marquee"
			priority
			fit="cover"
			aria-hidden="true"
			class="h-full w-auto max-w-none shrink-0"
		/>
	</div>
</section>

<style>
	.word-marquee-track {
		animation: word-marquee-scroll 80s linear infinite;
	}

	@keyframes word-marquee-scroll {
		to {
			transform: translateX(-40%);
		}
	}
</style>
