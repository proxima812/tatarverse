---
import ButtonLink from "../../ui/button/ButtonLink.astro";
import { links } from "@/data/links";
import { getLocaleFromUrl, useTranslations } from "@/i18n";
import { Icon } from "astro-icon/components";

const currentLocale = getLocaleFromUrl(Astro.url);
const t = useTranslations(currentLocale);
const menuLinks = links.slice(2, 5);
const mainLinks = links.slice(0, 1);
const materialLinks = links.slice(1, 3).concat(links.slice(4, 5));
const policyLinks = links.slice(3, 4);
const otherLinks = links.slice(-2);
const codeLicenseHref = "https://github.com/proxima812/tatarverse/blob/main/LICENSE";
const contentLicenseHref = "https://github.com/proxima812/tatarverse/blob/main/CONTENT-LICENSE.md";
const developerHref = "https://github.com/proxima812";

const sectionTitleClass =
	"px-4 mb-4 text-xs font-semibold uppercase tracking-tight text-muted-foreground";
const mobileLinkClass = "w-full justify-start text-lg text-primary";
const mobileTextLinkClass =
	"w-full font-medium justify-start flex items-center px-4 py-2 text-lg text-primary";
---

<nav class="hidden space-x-3 sm:flex">
	{
		menuLinks.map((item) => (
			<ButtonLink
				variant="ghost"
				icon={item.icon}
				href={item.href}
				label={item.label}
				labelKey={item.labelKey}
			/>
		))
	}
</nav>

<div data-menu class="sm:hidden select-none">
	<button
		type="button"
		data-menu-toggle
		class="fixed grid top-6 left-6 z-[100] px-2 py-1.5 cursor-pointer place-items-center rounded-xl corner-squircle bg-background/90 text-xs text-foreground shadow-2xs ring ring-border-muted/50 backdrop-blur-md"
		aria-label={t("menu.open")}
		aria-controls="mobile-menu"
		aria-expanded="false"
	>
		<div class="items-center gap-1.5 flex">
			<svg
				width="13"
				height="10"
				viewBox="0 0 15 12"
				class="stroke-current"
				stroke-width="1.5"
				stroke-linecap="round"
				aria-hidden="true"
			>
				<line
					x1="0"
					y1="6"
					x2="15"
					y2="6"
					class="-translate-y-0.75"
					style="transform-box: view-box; transform-origin: center center;"></line>
				<line
					x1="0"
					y1="6"
					x2="15"
					y2="6"
					class="translate-y-0.75"
					style="transform-box: view-box; transform-origin: center center;"></line>
			</svg>
			<span>Меню</span>
		</div>
	</button>

	<nav
		id="mobile-menu"
		data-menu-list
		class="pointer-events-none fixed inset-0 z-[90] h-dvh overflow-hidden bg-background/95 opacity-0 backdrop-blur-xl transition-opacity duration-300 ease-out"
		aria-label={t("menu.mobile")}
	>
		<div class="h-full overflow-y-auto overscroll-contain px-5 pb-12 pt-24">
			<div class="flex flex-col gap-10">
				<section class="flex flex-col" aria-labelledby="mobile-menu-main">
					<h2 id="mobile-menu-main" class={sectionTitleClass}>
						{t("menu.main", undefined, "Menu")}
					</h2>
					{
						mainLinks.map((item) => (
							<ButtonLink
								variant="ghost"
								class={mobileLinkClass}
								href={item.href}
								label={item.label}
								labelKey={item.labelKey}
							/>
						))
					}
				</section>

				<section class="flex flex-col" aria-labelledby="mobile-menu-materials">
					<h2 id="mobile-menu-materials" class={sectionTitleClass}>
						{t("menu.materials", undefined, "Materials")}
					</h2>
					{
						materialLinks.map((item) => (
							<ButtonLink
								variant="ghost"
								class={mobileLinkClass}
								href={item.href}
								label={item.label}
								labelKey={item.labelKey}
							/>
						))
					}
				</section>

				<section class="flex flex-col" aria-labelledby="mobile-menu-legal">
					<h2 id="mobile-menu-legal" class={sectionTitleClass}>
						{t("menu.legal", undefined, "Legal")}
					</h2>
					{
						policyLinks.map((item) => (
							<ButtonLink
								variant="ghost"
								class={mobileLinkClass}
								href={item.href}
								label={item.label}
								labelKey={item.labelKey}
							/>
						))
					}
				</section>

				<section class="flex flex-col" aria-labelledby="mobile-menu-licenses">
					<h2 id="mobile-menu-licenses" class={sectionTitleClass}>
						{t("menu.licenses", undefined, "Licenses")}
					</h2>
					<a
						href={codeLicenseHref}
						target="_blank"
						rel="noreferrer noopener"
						class={`${mobileTextLinkClass} gap-2`}
					>
						<Icon name="mdi:code-tags" class="size-5 shrink-0" aria-hidden="true" />
						<span>MIT Code</span>
					</a>
					<a
						href={contentLicenseHref}
						target="_blank"
						rel="noreferrer noopener"
						class={`${mobileTextLinkClass} gap-2`}
					>
						<Icon name="mdi:file-document-outline" class="size-5 shrink-0" aria-hidden="true" />
						<span>CC BY 4.0 Content</span>
					</a>
				</section>

				<section class="flex flex-col" aria-labelledby="mobile-menu-other">
					<h2 id="mobile-menu-other" class={sectionTitleClass}>
						{t("menu.other", undefined, "Other")}
					</h2>
					{
						otherLinks.map((item) => (
							<ButtonLink
								variant="disabled"
								class={mobileLinkClass}
								href={item.href}
								label={item.label}
								labelKey={item.labelKey}
							/>
						))
					}
				</section>

				<section class="flex flex-col" aria-labelledby="mobile-menu-developer">
					<h2 id="mobile-menu-developer" class={sectionTitleClass}>
						{t("menu.developer", undefined, "Developer")}
					</h2>
					<a
						href={developerHref}
						target="_blank"
						rel="noreferrer noopener"
						class={`${mobileTextLinkClass} gap-2`}
					>
						<Icon name="mdi:github" class="size-5" aria-hidden="true" />
						<span>proxima812</span>
					</a>
				</section>
			</div>
		</div>
	</nav>
</div>

<script>
	document.querySelectorAll<HTMLElement>("[data-menu]").forEach((root) => {
		const toggle = root.querySelector<HTMLButtonElement>("[data-menu-toggle]");
		const list = root.querySelector<HTMLElement>("[data-menu-list]");

		if (!toggle || !list) return;

		let lockedScrollY = 0;

		const lockBody = () => {
			lockedScrollY = window.scrollY;
			document.documentElement.classList.add("overflow-hidden");
			document.body.classList.add("overflow-hidden", "touch-none");
			document.body.style.position = "fixed";
			document.body.style.top = `-${lockedScrollY}px`;
			document.body.style.left = "0";
			document.body.style.right = "0";
			document.body.style.width = "100%";
		};

		const unlockBody = () => {
			document.documentElement.classList.remove("overflow-hidden");
			document.body.classList.remove("overflow-hidden", "touch-none");
			document.body.style.position = "";
			document.body.style.top = "";
			document.body.style.left = "";
			document.body.style.right = "";
			document.body.style.width = "";
			window.scrollTo(0, lockedScrollY);
		};

		const setOpen = (isOpen: boolean) => {
			const wasOpen = toggle.getAttribute("aria-expanded") === "true";
			if (isOpen === wasOpen) return;

			toggle.setAttribute("aria-expanded", String(isOpen));
			list.classList.toggle("opacity-100", isOpen);
			list.classList.toggle("pointer-events-auto", isOpen);
			list.classList.toggle("pointer-events-none", !isOpen);

			if (isOpen) {
				lockBody();
			} else {
				unlockBody();
			}
		};

		toggle.addEventListener("click", () => {
			setOpen(toggle.getAttribute("aria-expanded") !== "true");
		});

		list.addEventListener("click", (event) => {
			if (event.target instanceof Element && event.target.closest("a")) {
				setOpen(false);
			}
		});

		document.addEventListener("keydown", (event) => {
			if (event.key === "Escape") setOpen(false);
		});
	});
</script>
