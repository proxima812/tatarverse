---
import SocialButton from "@/components/widgets/SocialButton.astro";
import { getLocaleFromUrl, useTranslations } from "@/i18n";
import { cn } from "@/utils/libs/cn";
import { Icon } from "astro-icon/components";

interface Props {
	href?: string;
	children?: string;
	class?: string;
}

type LinkView = {
	label: string;
	ariaLabel: string;
	ariaKey: string;
	ariaValue: string;
	icon: string;
	isExternal: boolean;
	social: string | null;
};

const { href = "", children, class: className } = Astro.props as Props;
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const rawText = typeof children === "string" ? children.trim() : "";

const socialByHost: Record<string, string> = {
	"t.me": "telegram",
	"telegram.me": "telegram",
	"telegram.org": "telegram",
	"github.com": "github",
	"instagram.com": "instagram",
	"youtube.com": "youtube",
	"youtu.be": "youtube",
	"vk.com": "vk",
	"vkontakte.ru": "vk",
	"wa.me": "whatsapp",
	"whatsapp.com": "whatsapp",
	"chat.whatsapp.com": "whatsapp",
	"linkedin.com": "linkedin",
	"x.com": "x",
	"twitter.com": "x",
	"discord.com": "discord",
	"discord.gg": "discord",
	"tiktok.com": "tiktok",
	"dribbble.com": "dribbble",
	"behance.net": "behance",
	"facebook.com": "facebook",
};

const baseLinkClass =
	"inline-flex items-center gap-1.5 align-baseline text-foreground underline decoration-current/40 decoration-2 underline-offset-3 transition-colors hover:text-primary";
const iconClass = "h-4 w-4 shrink-0 text-current opacity-70";
const socialClass = "h-auto justify-start border-0 bg-transparent px-0 py-0 text-base leading-normal";

const defaultView = (value: string): LinkView => ({
	label: rawText || value,
	ariaLabel: `Open link: ${value}`,
	ariaKey: "link.open",
	ariaValue: value,
	icon: "mdi:link",
	isExternal: false,
	social: null,
});

const emailView = (value: string): LinkView => ({
	label: rawText || value.replace(/^mailto:/, ""),
	ariaLabel: `Send email: ${rawText || value.replace(/^mailto:/, "")}`,
	ariaKey: "link.mail",
	ariaValue: rawText || value.replace(/^mailto:/, ""),
	icon: "mdi:email-outline",
	isExternal: false,
	social: null,
});

const phoneView = (value: string): LinkView => ({
	label: rawText || value.replace(/^(tel:|sms:)/, ""),
	ariaLabel:
		value.startsWith("sms:")
			? `Send message: ${rawText || value.replace(/^sms:/, "")}`
			: `Call: ${rawText || value.replace(/^tel:/, "")}`,
	ariaKey: value.startsWith("sms:") ? "link.sms" : "link.phone",
	ariaValue: rawText || value.replace(/^(tel:|sms:)/, ""),
	icon: value.startsWith("sms:") ? "mdi:message-outline" : "mdi:phone-outline",
	isExternal: false,
	social: null,
});

const siteView = (value: string): LinkView => {
	try {
		const url = new URL(value);
		const hostname = url.hostname.replace(/^www\./, "");
		return {
			label: rawText || hostname,
			ariaLabel: `Open website: ${hostname}`,
			ariaKey: "link.site",
			ariaValue: hostname,
			icon: "mdi:open-in-new",
			isExternal:
				["http:", "https:"].includes(url.protocol) && url.origin !== Astro.site?.origin,
			social: socialByHost[hostname] ?? null,
		};
	} catch {
		const cleaned = value
			.replace(/^https?:\/\//, "")
			.replace(/^www\./, "")
			.replace(/\/$/, "")
			.split("/")[0];

		return defaultView(cleaned || value);
	}
};

const view =
	href.startsWith("mailto:")
		? emailView(href)
		: href.startsWith("tel:") || href.startsWith("sms:")
			? phoneView(href)
			: siteView(href);

const externalAttrs = view.isExternal
	? { target: "_blank", rel: "noopener noreferrer nofollow" }
	: {};
const ariaLabel = t(view.ariaKey, { value: view.ariaValue }, view.ariaLabel);
---

{
	view.social ? (
		<SocialButton
			href={href}
			social={view.social}
			title={view.label}
			ariaLabel={ariaLabel}
			iconStyle="mono"
			variant="ghost"
			size="sm"
			class={cn(baseLinkClass, socialClass, className)}
			labelClass="leading-normal"
			iconClass="text-current opacity-70"
			{...externalAttrs}
		/>
	) : (
		<a
			href={href}
			class={cn(baseLinkClass, className)}
			aria-label={ariaLabel}
			{...externalAttrs}
		>
			<Icon name={view.icon} class={iconClass} />
			<span>{view.label}</span>
		</a>
	)
}
