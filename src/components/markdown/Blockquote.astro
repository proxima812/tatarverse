---
import { cn } from "@/utils/libs/cn";
import { markdownClasses } from "./styles";

interface Props {
	class?: string;
}

const { class: className } = Astro.props as Props;
---

<blockquote class={cn(markdownClasses.blockquote, className)}>
	<div>
		<slot />
	</div>

	<cite class="mt-3 block text-sm not-italic opacity-70"> — tatarverse </cite>
</blockquote>
