---
import { getLocaleFromUrl, useTranslations } from "@/i18n";
import { Icon } from "astro-icon/components";

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<button
	type="button"
	data-back-to-top
	aria-label={t("nav.backToTop")}
	class="pointer-events-none fixed bottom-5 right-5 z-40 inline-flex size-10 translate-y-3 items-center justify-center rounded-full border border-border-muted bg-background/90 text-foreground opacity-0 shadow-2xs backdrop-blur transition hover:bg-muted focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/40 sm:bottom-6 sm:right-6"
>
	<Icon name="mdi:arrow-up" class="size-5" aria-hidden="true" />
</button>

<script>
	const button = document.querySelector<HTMLButtonElement>("[data-back-to-top]");

	if (button) {
		const setVisible = () => {
			const isVisible = window.scrollY > 300;
			button.classList.toggle("pointer-events-none", !isVisible);
			button.classList.toggle("translate-y-3", !isVisible);
			button.classList.toggle("opacity-0", !isVisible);
			button.classList.toggle("translate-y-0", isVisible);
			button.classList.toggle("opacity-100", isVisible);
		};

		button.addEventListener("click", () => {
			window.scrollTo({ top: 0, behavior: "smooth" });
		});

		window.addEventListener("scroll", setVisible, { passive: true });
		setVisible();
	}
</script>
