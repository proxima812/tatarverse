---
import Container from "@/components/partials/Container.astro";
import release from "@/data/release.json";
import { getLocaleFromUrl, localizePath, useTranslations } from "@/i18n";
import { Icon } from "astro-icon/components";

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const policyHref = localizePath(locale, "/policy");
const updatedAtLabel = new Intl.DateTimeFormat(locale, {
	day: "numeric",
	month: "long",
	year: "numeric",
	hour: "2-digit",
	minute: "2-digit",
	hour12: false,
	timeZone: "Asia/Almaty",
}).format(new Date(release.updatedAt));
---

<footer class="mt-auto border-t border-border-muted py-6 text-xs text-subtle-foreground">
	<Container container>
		<div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
			<div class="space-y-1">
				<p>&copy; tatarverse.cc {new Date().getFullYear()}</p>
				<p>v{release.version} · {t("footer.updated", { date: updatedAtLabel })}</p>
			</div>

			<nav
				aria-label={t("footer.links")}
				class="flex flex-wrap items-center gap-x-3 gap-y-1 sm:justify-end"
			>
				<a
					href={policyHref}
					class="text-link underline decoration-link-decoration underline-offset-4 transition hover:decoration-link"
				>
					{t("footer.privacy")}
				</a>
				<span class="text-subtle-foreground" aria-hidden="true">·</span>
				<a
					href="https://github.com/proxima812/tatarverse/blob/main/LICENSE"
					target="_blank"
					rel="noreferrer noopener"
					class="text-link underline decoration-link-decoration underline-offset-4 transition hover:decoration-link"
				>
					MIT Code
				</a>
				<span class="text-subtle-foreground" aria-hidden="true">·</span>
				<a
					href="https://github.com/proxima812/tatarverse/blob/main/CONTENT-LICENSE.md"
					target="_blank"
					rel="noreferrer noopener"
					class="text-link underline decoration-link-decoration underline-offset-4 transition hover:decoration-link"
				>
					CC BY 4.0 Content
				</a>
				<span class="text-subtle-foreground" aria-hidden="true">·</span>
				<a
					href="https://github.com/proxima812"
					target="_blank"
					rel="noreferrer noopener"
					class="inline-flex items-center gap-1.5 text-link underline decoration-link-decoration underline-offset-4 transition hover:decoration-link"
				>
					<Icon name="mdi:github" class="size-4" aria-hidden="true" />
					<span>proxima812</span>
				</a>
				<span class="text-subtle-foreground" aria-hidden="true">·</span>
				<a
					href="https://github.com/proxima812/tatarverse"
					target="_blank"
					rel="noreferrer noopener"
					class="inline-flex items-center gap-1.5 text-link underline decoration-link-decoration underline-offset-4 transition hover:decoration-link"
				>
					<Icon name="mdi:github" class="size-4" aria-hidden="true" />
					<span>Open Source</span>
				</a>
			</nav>
		</div>
	</Container>
</footer>
