---
import {
	getLocaleFromUrl,
	getSwitcherHref,
	localeLabels,
	locales,
	useTranslations,
	type AppLocale,
} from "@/i18n";

type LanguageItem = {
	value: AppLocale;
	label: string;
	text: Uppercase<AppLocale>;
	href: string;
};

const currentLocale = getLocaleFromUrl(Astro.url);
const t = useTranslations(currentLocale);
const items = locales.map((locale) => ({
	value: locale,
	label: localeLabels[locale].label,
	text: localeLabels[locale].short,
	href: getSwitcherHref(locale, Astro.url),
})) satisfies readonly LanguageItem[];

const triggerClass =
	"inline-flex h-8 min-w-14 items-center justify-between gap-2 rounded-full border border-border-muted bg-background px-3 tracking-tight text-xs font-medium text-subtle-foreground transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/40";

const buttonClass =
	"inline-flex h-8 w-full items-center justify-between rounded-full px-3 tracking-tight text-xs font-medium text-subtle-foreground transition-colors hover:bg-muted hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/40 aria-checked:bg-muted aria-checked:text-foreground";
---

<div class="relative z-50 inline-flex" data-language-switcher>
	<button
		type="button"
		class={triggerClass}
		aria-label={t("language.switcher")}
		aria-haspopup="menu"
		aria-expanded="false"
		data-language-trigger
	>
		<span data-language-current>{localeLabels[currentLocale].short}</span>

		<svg
			aria-hidden="true"
			viewBox="0 0 16 16"
			class="size-3.5 shrink-0"
			fill="none"
			stroke="currentColor"
			stroke-width="1.5"
		>
			<path d="M4 6l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	</button>

	<div
		class="absolute top-full right-0 z-20 mt-2 min-w-40 rounded-2xl border border-border-muted bg-background p-1 shadow-sm"
		role="menu"
		hidden
		data-language-menu
	>
		{
			items.map((item) => {
				const isActive = item.value === currentLocale;

				return (
					<a
						href={item.href}
						class={buttonClass}
						data-language-option={item.value}
						role="menuitemradio"
						aria-label={item.label}
						aria-checked={isActive ? "true" : "false"}
						aria-current={isActive ? "true" : undefined}
						tabindex={isActive ? "0" : "-1"}
					>
						<span>{item.label}</span>
						<span class="text-[11px] uppercase text-primary/40">{item.text}</span>
					</a>
				);
			})
		}
	</div>
</div>

<script>
	const switchers = document.querySelectorAll<HTMLElement>("[data-language-switcher]");

	for (const switcher of switchers) {
		const trigger = switcher.querySelector<HTMLButtonElement>("[data-language-trigger]");
		const menu = switcher.querySelector<HTMLElement>("[data-language-menu]");
		const current = switcher.querySelector<HTMLElement>("[data-language-current]");
		const options = Array.from(switcher.querySelectorAll<HTMLElement>("[data-language-option]"));

		if (!trigger || !menu || !current || options.length === 0) continue;

		const openMenu = (): void => {
			menu.hidden = false;
			trigger.setAttribute("aria-expanded", "true");
		};

		const closeMenu = (): void => {
			menu.hidden = true;
			trigger.setAttribute("aria-expanded", "false");
		};

		const toggleMenu = (): void => {
			if (menu.hidden) {
				openMenu();
				return;
			}

			closeMenu();
		};

		trigger.addEventListener("click", () => {
			toggleMenu();
		});

		trigger.addEventListener("keydown", (event) => {
			if (event.key !== "ArrowDown" && event.key !== "Enter" && event.key !== " ") return;

			event.preventDefault();
			openMenu();

			const active = options.find((option) => option.getAttribute("aria-checked") === "true");
			active?.focus();
		});

		switcher.addEventListener("click", (event) => {
			const target = event.target;

			if (!(target instanceof Element)) return;

			const option = target.closest<HTMLButtonElement>("[data-language-option]");

			if (!option) return;
			closeMenu();
		});

		switcher.addEventListener("keydown", (event) => {
			if (event.key === "Escape") {
				closeMenu();
				trigger.focus();
				return;
			}

			if (menu.hidden) return;

			const activeIndex = options.findIndex(
				(option) => option.getAttribute("aria-checked") === "true",
			);

			if (event.key === "ArrowDown") {
				event.preventDefault();

				const nextIndex = activeIndex >= options.length - 1 ? 0 : activeIndex + 1;
				options[nextIndex]?.focus();
				return;
			}

			if (event.key === "ArrowUp") {
				event.preventDefault();

				const previousIndex = activeIndex <= 0 ? options.length - 1 : activeIndex - 1;
				options[previousIndex]?.focus();
			}
		});

		document.addEventListener("click", (event) => {
			const target = event.target;

			if (target instanceof Node && !switcher.contains(target)) {
				closeMenu();
			}
		});
	}
</script>
