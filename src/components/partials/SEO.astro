---
import { config } from "@/config";

interface VerificationMeta {
	name_verification: string;
	content: string;
}

interface Props {
	datePublished?: string | Date;
	dateModified?: string | Date;
	indexRobots?: boolean;
	name?: string;
	author?: string;
	title?: string;
	type?: "article" | "website";
	keywords?: string | string[];
	description?: string;
	ogImage?: string | URL;
	locale?: string;
	canonicalURL?: string | URL;
}

const {
	datePublished,
	dateModified,
	indexRobots,
	name,
	author,
	title,
	type,
	keywords,
	description,
	ogImage,
	locale,
	canonicalURL = new URL(Astro.url.pathname, Astro.site),
} = Astro.props as Props;

function formatCanonicalURL(url: string | URL) {
	const path = url.toString();
	const hasQueryParams = path.includes("?");

	return hasQueryParams ? path.replace(/\/$/, "") : path.replace(/\/?$/, "/");
}

function normalizeMetaValue(value?: string | string[]) {
	if (Array.isArray(value)) {
		return value.filter(Boolean).join(", ");
	}

	return value;
}

const socialImageURL = new URL(
	ogImage ? ogImage : `/${config.site.OG.defaultImage}`,
	Astro.url,
).href;

const pageType = type === "article" ? "article" : "website";
const schemaType = pageType === "article" ? "BlogPosting" : "WebPage";
const mainTitle = title || config.site.OG.title;

const mainDescription = description
	? description
	: config.site.OG.description;

const mainAuthor = author || config.site.OG.author;
const mainOGImage = socialImageURL || config.site.OG.defaultImage;
const mainLocale = locale || config.site.OG.locale;
const mainSiteName = name || config.site.OG.site_name;
const mainKeywords = normalizeMetaValue(keywords) || config.site.OG.keywords;

function formatDateToYYYYMMDD(date: Date): string {
	return date.toISOString().substring(0, 10);
}

function toIsoString(value?: string | Date) {
	if (!value) return undefined;

	const date = value instanceof Date ? value : new Date(value);
	return Number.isNaN(date.getTime()) ? undefined : date.toISOString();
}

const jsonLd = {
	"@context": "https://schema.org",
	"@type": schemaType,
	headline: mainTitle,
	description: mainDescription,
	keywords: mainKeywords,
	inLanguage: mainLocale,
	url: formatCanonicalURL(canonicalURL),
	image: mainOGImage,
	author: {
		"@type": "Person",
		name: mainAuthor,
		url: Astro.site,
	},
	publisher: {
		"@type": "Organization",
		name: config.site.name,
		logo: {
			"@type": "ImageObject",
			url: `${Astro.site}logo.png`,
		},
	},
	...(datePublished && {
		datePublished: formatDateToYYYYMMDD(new Date(datePublished)),
		dateModified: formatDateToYYYYMMDD(new Date(dateModified ?? datePublished)),
	}),
};

const articlePublishedTime = toIsoString(datePublished);
const articleModifiedTime = toIsoString(dateModified);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="theme-color" content="#080214" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta name="apple-mobile-web-app-title" content="Xima Tatars" />
<meta name="msapplication-TileColor" content="#080214" />
<meta name="msapplication-TileImage" content="/mstile-150x150.png" />
<link rel="alternate" type="text/plain" href="/llms.txt" title="LLMS Index" />
<meta name="generator" content={Astro.generator} />
{canonicalURL && <link rel="canonical" href={formatCanonicalURL(canonicalURL)} />}
<title>{mainTitle}</title>
<meta name="title" content={mainTitle} />
<meta name="description" content={mainDescription} />
<meta name="author" content={mainAuthor} />
<meta property="og:type" content={pageType} />
{canonicalURL && <meta property="og:url" content={formatCanonicalURL(canonicalURL)} />}
<meta property="og:title" content={mainTitle} />
<meta property="og:description" content={mainDescription} />
<meta property="og:image" content={mainOGImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content={mainLocale} />
<meta property="og:site_name" content={mainSiteName} />
<meta name="keywords" content={mainKeywords} />
{
	pageType === "article" && (
		<>
			<meta property="article:author" content={mainAuthor} />
			{articlePublishedTime && (
				<meta property="article:published_time" content={articlePublishedTime} />
			)}
			{articleModifiedTime && (
				<meta property="article:modified_time" content={articleModifiedTime} />
			)}
		</>
	)
}
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={formatCanonicalURL(canonicalURL)} />
<meta property="twitter:title" content={mainTitle} />
<meta property="twitter:description" content={mainDescription} />
<meta property="twitter:image" content={mainOGImage} />
<meta
	name="robots"
	content={indexRobots === false
		? "noindex, nofollow"
		: "index, follow, max-image-preview:large"}
/>

<link type="text/plain" rel="author" href={`${Astro.site}humans.txt`} />
<link
	rel="alternate"
	type="application/rss+xml"
	title="RSS"
	href={new URL("/posts/rss.xml", Astro.site)}
/>

<link rel="sitemap" href="/sitemap-index.xml" />

{
	config.site.verifications &&
		config.site.verifications.some(
			(verification: VerificationMeta) =>
				verification.name_verification && verification.content,
		) &&
		config.site.verifications.map((verification: VerificationMeta) =>
			verification.name_verification && verification.content ? (
				<meta name={verification.name_verification} content={verification.content} />
			) : null,
		)
}
<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<!-- =========================
	FAVICON / APP ICONS
	Рекомендуемые размеры
========================= -->

<!-- Классический favicon (старые браузеры, fallback)
	Файл: /favicon.ico
	Внутри .ico желательно иметь:
	16x16, 32x32, 48x48 -->
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />

<!-- SVG favicon (современные браузеры, идеальный вариант)
	Файл: /favicon.svg
	Векторный, масштабируется без потери качества -->
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />

<!-- Apple Touch Icon (iOS: Safari, добавление на экран)
	Файл: /apple-touch-icon.png
	Рекомендуемый размер: 180x180 -->
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="apple-touch-icon" sizes="152x152" href="/icon-152x152.png" />
<link rel="apple-touch-icon" sizes="167x167" href="/icon-167x167.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

<!-- Web App Manifest (Android, PWA, Chrome, Edge)
	Файл: /site.webmanifest
	Иконки внутри manifest:
	- 192x192 (обязательно)
	- 512x512 (обязательно) -->
<link rel="manifest" href="/site.webmanifest" />

<!--
/public
├─ favicon.ico          → 16x16, 32x32, 48x48 (в одном файле)
├─ favicon.svg          → SVG
├─ apple-touch-icon.png → 180x180
├─ icon-192.png         → 192x192 (Android / PWA)
├─ icon-512.png         → 512x512 (Android / PWA)
└─ site.webmanifest
-->

