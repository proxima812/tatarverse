	size?: Size;
	shape?: Shape;
	iconOnly?: boolean;
	iconPosition?: IconPosition;
	iconSize?: number;
	iconStyle?: IconStyle;
	fullWidth?: boolean;
	external?: boolean;
	target?: string;
	rel?: string;
	labelClass?: string;
	iconClass?: string;
}

const variantClasses: Record<Variant, string> = {
	solid:
		"border border-primary bg-primary text-primary-foreground hover:border-primary/80 hover:bg-primary/80",
	outline:
		"border border-border bg-surface text-surface-foreground hover:border-ring hover:bg-surface-muted",
	ghost:
		"border border-transparent bg-transparent text-muted-foreground hover:bg-muted hover:text-foreground",
	soft: "border border-border-muted bg-muted text-foreground hover:border-border hover:bg-subtle",
};

const sizeClasses: Record<Size, string> = {
	sm: "h-9 px-3 text-sm gap-2",
	md: "h-10 px-4 text-sm gap-2.5",
	lg: "h-12 px-5 text-base gap-3",
};

const shapeClasses: Record<Shape, string> = {
	rounded: "rounded-xl",
	pill: "rounded-full",
	square: "rounded-md",
};

const iconOnlySizeClasses: Record<Size, string> = {
	sm: "w-9 px-0",
	md: "w-10 px-0",
	lg: "w-12 px-0",
};

const {
	class: className,
	href,
	title = "",
	aria_label,
	ariaLabel,
	social = "website",
	variant = "outline",
	size = "md",
	shape = "rounded",
	iconOnly = false,
	iconPosition = "left",
	iconSize = size === "lg" ? 20 : size === "sm" ? 16 : 18,
	iconStyle = "mono",
	fullWidth = false,
	external = /^https?:\/\//.test(href),
	target,
	rel,
	labelClass = "",
	iconClass = "",
	...props
} = Astro.props as Props;

const socialName = resolveSocialName(social);
const icon = socialIcons[socialName];
const computedLabel = ariaLabel ?? aria_label ?? title ?? icon.label;
const linkTarget = target ?? (external ? "_blank" : undefined);
const linkRel = rel ?? (external ? "noreferrer noopener" : undefined);
const iconColorStyle =
	iconStyle === "brand" && icon.brandColor ? `color:${icon.brandColor}` : undefined;
---

<a
	href={href}
	target={linkTarget}
	rel={linkRel}
	aria-label={computedLabel}
	title={computedLabel}
	class={cn(
		"group inline-flex shrink-0 items-center justify-center whitespace-nowrap transition-colors duration-200",
		variantClasses[variant],
		sizeClasses[size],
		shapeClasses[shape],
		iconOnly && iconOnlySizeClasses[size],
		fullWidth && "w-full",
		className,
	)}
	{...props}
>
	{
		iconPosition === "left" && (
			<svg
				viewBox={icon.viewBox}
				width={iconSize}
				height={iconSize}
				class={cn("shrink-0 text-current", iconClass)}
				style={iconColorStyle}
				aria-hidden="true"
			>
				<Fragment set:html={icon.body} />
			</svg>
		)
	}

	{
		!iconOnly && (
			<span class={cn("inline-block leading-none", labelClass)}>{title || icon.label}</span>
		)
	}

	{
		iconPosition === "right" && (
			<svg
				viewBox={icon.viewBox}
				width={iconSize}
				height={iconSize}
				class={cn("shrink-0 text-current", iconClass)}
				style={iconColorStyle}
				aria-hidden="true"
			>
				<Fragment set:html={icon.body} />
			</svg>
		)
	}
</a>
