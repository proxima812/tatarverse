---
import { cn } from "@/utils/libs/cn";
import SocialButton from "./SocialButton.astro";

type Variant = "solid" | "outline" | "ghost" | "soft";
type Size = "sm" | "md" | "lg";
type Shape = "rounded" | "pill" | "square";
type IconPosition = "left" | "right";
type Justify = "start" | "center" | "end" | "between";
type IconStyle = "mono" | "brand";

type SocialItem = {
	title?: string;
	href: string;
	aria_label?: string;
	ariaLabel?: string;
	social?: string;
	variant?: Variant;
	size?: Size;
	shape?: Shape;
	iconOnly?: boolean;
	iconPosition?: IconPosition;
	iconSize?: number;
	iconStyle?: IconStyle;
	fullWidth?: boolean;
	external?: boolean;
	target?: string;
	rel?: string;
	class?: string;
	labelClass?: string;
	iconClass?: string;
};

interface Props {
	data?: SocialItem[];
	class?: string;
	itemClass?: string;
	variant?: Variant;
	size?: Size;
	shape?: Shape;
	iconOnly?: boolean;
	iconPosition?: IconPosition;
	iconSize?: number;
	iconStyle?: IconStyle;
	fullWidth?: boolean;
	wrap?: boolean;
	justify?: Justify;
	gap?: string;
}

const justifyClasses: Record<Justify, string> = {
	start: "justify-start",
	center: "justify-center",
	end: "justify-end",
	between: "justify-between",
};

const {
	data = [],
	class: className = "",
	itemClass = "",
	variant = "outline",
	size = "md",
	shape = "rounded",
	iconOnly = false,
	iconPosition = "left",
	iconSize,
	iconStyle = "mono",
	fullWidth = false,
	wrap = true,
	justify = "start",
	gap = "0.75rem",
} = Astro.props as Props;
---

<div
	class={cn(
		"flex items-center",
		wrap ? "flex-wrap" : "flex-nowrap overflow-x-auto",
		justifyClasses[justify],
		className,
	)}
	style={`gap:${gap}`}
>
	{
		data.map((item) => (
			<SocialButton
				href={item.href}
				title={item.title}
				aria_label={item.aria_label}
				ariaLabel={item.ariaLabel}
				social={item.social}
				variant={item.variant ?? variant}
				size={item.size ?? size}
				shape={item.shape ?? shape}
				iconOnly={item.iconOnly ?? iconOnly}
				iconPosition={item.iconPosition ?? iconPosition}
				iconSize={item.iconSize ?? iconSize}
				iconStyle={item.iconStyle ?? iconStyle}
				fullWidth={item.fullWidth ?? fullWidth}
				external={item.external}
				target={item.target}
				rel={item.rel}
				class={cn(itemClass, item.class)}
				labelClass={item.labelClass}
				iconClass={item.iconClass}
			/>
		))
	}
</div>
