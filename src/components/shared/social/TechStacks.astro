---
import { cn } from "@/utils/libs/cn";
type StackCategory = "frontend" | "backend" | "platform";

type StackDefinition = {
	label: string;
	category: StackCategory;
	aliases: string[];
	href: string;
	src: string;
};

const toDataUri = (svg: string) => `data:image/svg+xml;utf8,${encodeURIComponent(svg.trim())}`;
const toStackSrc = (source: string) =>
	source.trim().startsWith("<svg") ? toDataUri(source) : source;

const createStack = (
	label: string,
	category: StackCategory,
	aliases: string[],
	href: string,
	source: string,
): StackDefinition => ({
	label,
	category,
	aliases,
	href,
	src: toStackSrc(source),
});

