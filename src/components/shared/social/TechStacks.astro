type StackKey = keyof typeof stackIcons;

const stackEntries = Object.entries(stackIcons) as Array<[StackKey, StackDefinition]>;

const stackAliasMap = stackEntries.reduce<Record<string, StackKey>>((acc, [key, item]) => {
	for (const alias of item.aliases) {
		acc[alias.toLowerCase()] = key;
	}
	return acc;
}, {});

const resolveStackIcon = (value?: string) => {
	if (!value) return null;
	const key = stackAliasMap[value.trim().toLowerCase()];
	return key ? stackIcons[key] : null;
};

type Size = "xs" | "sm" | "md" | "lg";

interface Props {
	stacks?: string[];
	class?: string;
	itemClass?: string;
	size?: Size;
	iconOnly?: boolean;
	wrap?: boolean;
	gap?: string;
}

