---
import { Icon } from "astro-icon/components";

interface Link {
	type: string;
	url: string;
	label?: string;
}

interface Location {
	flag?: string;
	city?: string;
	country?: string;
	address?: string;
}

interface Props {
	id: string;
	title?: string;
	summary?: string;
	location?: Location;
	links?: Link[];
	pubDate?: string | Date;
	region?: string;
}

const { id, title, summary, location, links = [], pubDate, region } = Astro.props;

const NINETY_DAYS = 90 * 24 * 60 * 60 * 1000;
const isNew = pubDate ? Date.now() - new Date(pubDate).getTime() < NINETY_DAYS : false;

const NO_DATA = "Нет данных.";
const cleanFlag = location?.flag && location.flag !== NO_DATA ? location.flag : undefined;
const cleanCity = location?.city && location.city !== NO_DATA ? location.city : undefined;
const cleanCountry =
	location?.country && location.country !== NO_DATA ? location.country : undefined;
const locationParts = [cleanCity, cleanCountry].filter(Boolean);
const locationLine = locationParts.join(", ");
const countryKey = cleanCountry ?? "Прочее";

const isDump =
	summary &&
	(summary.startsWith("Полное название:") ||
		summary.startsWith("Тел.:") ||
		summary.startsWith("Адрес:") ||
		summary.length > 400);
const displaySummary = isDump ? undefined : summary;

const socialLinks = links.filter((l) => !["email", "phone"].includes(l.type.toLowerCase()));

const iconMap: Record<string, string> = {
	instagram: "mdi:instagram",
	telegram: "mdi:telegram",
	vk: "mdi:vk",
	facebook: "mdi:facebook",
	youtube: "mdi:youtube",
	tiktok: "mdi:tiktok",
	twitter: "mdi:twitter",
	site: "mdi:web",
	web: "mdi:web",
	website: "mdi:web",
};

function getIcon(type: string): string {
	return iconMap[type.toLowerCase()] ?? "mdi:web";
}
---

<a
	href={`/list/centers/${id}`}
	data-country={countryKey}
	data-region={region ?? ""}
	data-title={title ?? ""}
	data-summary={summary ?? ""}
	data-city={cleanCity ?? ""}
	data-date={pubDate ? new Date(pubDate).toISOString() : ""}
	class="block h-full"
>
	<article
		class="group h-full relative flex flex-col gap-3 rounded-2xl corner-squircle bg-white p-5 ring-1 ring-zinc-200/80 transition-all hover:shadow-sm hover:ring-zinc-300"
	>
		<div class="flex items-start justify-between gap-2">
			{
				(cleanFlag || locationLine) && (
					<div class="flex items-center gap-1.5 text-xs text-zinc-400">
						{cleanFlag && <span class="text-base leading-none">{cleanFlag}</span>}
						{locationLine && <span>{locationLine}</span>}
					</div>
				)
			}
		</div>

		<h2 class="line-clamp-2 font-semibold leading-snug text-zinc-900">
			{title ?? "—"}
		</h2>

		{
			displaySummary && (
				<p class="line-clamp-3 grow text-xs leading-relaxed text-zinc-500">{displaySummary}</p>
			)
		}

		<div class="mt-auto flex items-center justify-between gap-2 pt-1">
			{
				socialLinks.length > 0 && (
					<div class="flex flex-wrap gap-1.5">
						{socialLinks.map((link) => (
							<a
								href={link.url}
								target="_blank"
								rel="noopener noreferrer"
								title={link.label ?? link.type}
								class="flex h-7 w-7 items-center justify-center rounded-lg corner-squircle bg-zinc-100 text-zinc-500 transition hover:bg-zinc-200 hover:text-zinc-800"
							>
								<Icon name={getIcon(link.type)} class="h-4 w-4" />
							</a>
						))}
					</div>
				)
			}
		</div>
	</article>
</a>
