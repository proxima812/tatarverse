---
import {
	countryFlagsByRu,
	getCountryGradient,
	getCountryLabel,
	getCountryLabels,
} from "@/data/worldCountries";
import { getLocaleFromUrl, localizePath, useTranslations } from "@/i18n";
import { getCenterPath } from "@/utils/centers";
import { Icon } from "astro-icon/components";

type IconName = "tt" | "qt" | "bs";
type Category = "Татарский" | "Татаро-Башкирский" | "Башкирский" | "Крымотатарский";
const categoryIconMap: Record<Category, IconName[]> = {
	Татарский: ["tt"],
	"Татаро-Башкирский": ["tt", "bs"],
	Башкирский: ["bs"],
	Крымотатарский: ["qt"],
};
interface Location {
	flag?: string;
	city?: string;
	country?: string;
}

interface Props {
	id: string;
	routeId?: string;
	title?: string;
	summary?: string;
	type?: string;
	category?: string;
	location?: Location;
	region?: string;
	pubDate?: string;
}

const { id, routeId, title, summary, type, category, location, region, pubDate } =
	Astro.props as Props;
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const centerPath = getCenterPath(routeId ?? id);

const NO_DATA = "Нет данных.";
const cleanCity = location?.city && location.city !== NO_DATA ? location.city : undefined;
const cleanCountry =
	location?.country && location.country !== NO_DATA ? location.country : undefined;
const cleanFlag =
	location?.flag && location.flag !== NO_DATA
		? location.flag
		: cleanCountry
			? countryFlagsByRu[cleanCountry]
			: undefined;
const displayCountry = cleanCountry ? getCountryLabel(cleanCountry, locale) : undefined;
const countryKey = cleanCountry ?? "Прочее";
const countryGradient = getCountryGradient(cleanCountry);
const countryLabels = cleanCountry ? getCountryLabels(cleanCountry) : undefined;
const displayTitle = title ?? "—";
const displaySummary = summary?.trim();
const displayLocation =
	cleanFlag || cleanCity || displayCountry
		? { flag: cleanFlag, city: cleanCity, country: displayCountry, countryLabels }
		: null;
const formattedDate =
	pubDate &&
	!Number.isNaN(new Date(pubDate).getTime()) &&
	new Intl.DateTimeFormat(locale, { month: "short", year: "numeric" }).format(new Date(pubDate));

const icons = categoryIconMap[category as Category] ?? [];
const hasIcons = icons.length > 0;
const truncate = (value?: string, max = 23) => {
	if (!value) return "";
	const v = value.trim();
	return v.length > max ? v.slice(0, max).trimEnd() + "…" : v;
};
---

<a
	data-type={type ?? ""}
	data-category={category ?? ""}
	data-country={countryKey}
	data-search-id={id}
	data-title={displayTitle}
	data-summary={summary ?? ""}
	data-city={cleanCity ?? ""}
	data-region={region ?? ""}
	href={localizePath(locale, centerPath)}
	class="block min-w-0 rounded-4xl corner-squircle text-surface-foreground no-underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary "
>
	<article
		class="group relative flex h-full overflow-hidden rounded-4xl corner-squircle bg-muted p-5 shadow-2xs ring ring-depth-100/40 transition duration-300 ease-out hover:bg-surface-muted hover:ring-depth-200 sm:p-6 flex-col justify-between"
	>
		{
			countryGradient && (
				<span
					aria-hidden="true"
					class="pointer-events-none absolute inset-y-0 left-0 w-2/5 opacity-[0.12] transition-opacity duration-300 ease-out group-hover:opacity-[0.18]"
					style={`background-image:${countryGradient};-webkit-mask-image:linear-gradient(to right, #000, transparent);mask-image:linear-gradient(to right, #000, transparent);`}
				/>
			)
		}
		<div class="relative space-y-4">
			<div class="flex min-w-0 items-start justify-between gap-3">
				<div class="flex min-w-0 flex-wrap items-center gap-x-2 gap-y-1 text-surface-foreground">
					{
						hasIcons && (
							<div data-card-section="icons" class="flex shrink-0 gap-0.5">
								{icons.map((name) => (
									<Icon
										name={name}
										class="pointer-events-none size-7 shrink-0 [&:not([class*='size-'])]:size-4"
									/>
								))}
							</div>
						)
					}
					{
						displayLocation && (
							<div
								data-card-section="location"
								class="flex min-w-0 items-center gap-1.5 text-xs text-muted-foreground"
							>
								{displayLocation.flag && (
									<span class="shrink-0 text-base leading-none">{displayLocation.flag}</span>
								)}
								{displayLocation.city && (
									<span>{truncate(displayLocation.city.trim(), 16)}</span>
								)}
								{displayLocation.city && displayLocation.countryLabels && (
									<span aria-hidden="true">&#10625;</span>
								)}
								{displayLocation.countryLabels && (
									<span
										data-country-label={cleanCountry}
										data-country-labels={JSON.stringify(displayLocation.countryLabels)}
									>
										{displayLocation.country}
									</span>
								)}
							</div>
						)
					}
				</div>
				<span class="shrink-0 rounded-full bg-surface px-2 py-1 text-xs font-medium text-muted-foreground ring ring-depth-100/60">
					{t("card.details")}
				</span>
			</div>
			<h2
				data-card-section="title"
				class="min-w-0 wrap-anywhere text-lg font-bold leading-snug tracking-tight text-surface-foreground sm:text-xl"
			>
				{displayTitle}
			</h2>
			{
				displaySummary && (
					<p class="line-clamp-2 max-w-3xl text-sm leading-6 text-muted-foreground">
						{displaySummary}
					</p>
				)
			}
			</div>
			<div class="relative mt-5 flex flex-wrap items-center gap-1.5 text-xs font-semibold text-surface-foreground">
				<div class="inline-flex min-h-7 max-w-full flex-wrap items-center overflow-hidden rounded-full bg-surface ring ring-depth-200/80">
					{type && <span class="px-2.5 py-1">{type}</span>}
					{
						category && (
							<span
								class:list={[
									"inline-flex items-center gap-1.5 px-2.5 py-1",
									type && "border-l border-depth-100/80",
								]}
							>
								{hasIcons && (
									<span class="inline-flex items-center gap-0.5" aria-hidden="true">
										{icons.map((icon) => (
											<Icon name={icon} class="size-3" />
										))}
									</span>
								)}
								{category}
							</span>
						)
					}
				</div>
				{
					formattedDate && (
						<span class="ml-auto inline-flex min-h-7 items-center rounded-full bg-surface/70 px-2 py-1 tabular-nums text-muted-foreground ring ring-depth-100/60">
							{formattedDate}
						</span>
					)
				}
			</div>
		</article>
	</a>
