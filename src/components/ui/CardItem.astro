---
import { getCountryLabel, getCountryLabels } from "@/data/worldCountries";
import { getLocaleFromUrl, localizePath, useTranslations } from "@/i18n";
import { getCenterPath } from "@/utils/centers";
import { Icon } from "astro-icon/components";

type IconName = "tt" | "qt" | "bs";
type Category = "Татарский" | "Татаро-Башкирский" | "Башкирский" | "Крымотатарский";
const categoryIconMap: Record<Category, IconName[]> = {
	Татарский: ["tt"],
	"Татаро-Башкирский": ["tt", "bs"],
	Башкирский: ["bs"],
	Крымотатарский: ["qt"],
};
interface Location {
	flag?: string;
	city?: string;
	country?: string;
}

interface Props {
	id: string;
	routeId?: string;
	title?: string;
	summary?: string;
	type?: string;
	category?: string;
	location?: Location;
	region?: string;
}

const { id, routeId, title, summary, type, category, location, region } = Astro.props as Props;
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const centerPath = getCenterPath(routeId ?? id);

const NO_DATA = "Нет данных.";
const cleanFlag = location?.flag && location.flag !== NO_DATA ? location.flag : undefined;
const cleanCity = location?.city && location.city !== NO_DATA ? location.city : undefined;
const cleanCountry =
	location?.country && location.country !== NO_DATA ? location.country : undefined;
const displayCountry = cleanCountry ? getCountryLabel(cleanCountry, locale) : undefined;
const countryKey = cleanCountry ?? "Прочее";
const countryLabels = cleanCountry ? getCountryLabels(cleanCountry) : undefined;
const displayTitle = title ?? "—";
const displayLocation =
	cleanFlag || cleanCity || displayCountry
		? { flag: cleanFlag, city: cleanCity, country: displayCountry, countryLabels }
		: null;

const icons = categoryIconMap[category as Category] ?? [];
const truncate = (value?: string, max = 23) => {
	if (!value) return "";
	const v = value.trim();
	return v.length > max ? v.slice(0, max).trimEnd() + "…" : v;
};
---

<article
	data-type={type ?? ""}
	data-category={category ?? ""}
	data-country={countryKey}
	data-title={displayTitle}
	data-summary={summary ?? ""}
	data-city={cleanCity ?? ""}
	data-region={region ?? ""}
	class="content-auto relative flex h-56 transform-gpu overflow-hidden rounded-4xl corner-squircle bg-muted p-5 shadow-2xs ring ring-depth-100/40 transition duration-500 ease-out sm:h-60 sm:p-6 flex-col justify-between motion-reduce:transform-none motion-reduce:transition-none mask-cover"
	style="contain-intrinsic-size: 240px"
>
	<div class="flex justify-center items-center">
		{
			displayLocation && (
				<div class="rounded-full bg-surface/70 backdrop-blur-lg ring-inset ring ring-border-muted corner-squircle px-3 py-1.5 shadow-2xs shrink-0 max-w-fit text-right text-xs text-surface-foreground">
					<div class="flex items-center gap-1.5">
						{displayLocation.flag && (
							<span class="text-base leading-none">{displayLocation.flag}</span>
						)}
						{displayLocation.city && (
							<span>{truncate(displayLocation.city.trim(), 12)}</span>
						)}
						{displayLocation.city && displayLocation.countryLabels && (
							<span aria-hidden="true">&#10625;</span>
						)}
						{displayLocation.countryLabels && (
							<span
								data-country-label={cleanCountry}
								data-country-labels={JSON.stringify(displayLocation.countryLabels)}
							>
								{displayLocation.country}
							</span>
						)}
					</div>
				</div>
			)
		}
	</div>
	<div>
		<h2
			class="text-center line-clamp-3 font-bold leading-snug tracking-tight mb-2 text-surface-foreground text-xl"
		>
			{displayTitle}
		</h2>
	</div>
	<div class="flex justify-between items-center">
		<div class="flex gap-0.5">
			{
				icons.map((name) => (
					<Icon
						name={name}
						class="shrink-0 pointer-events-none size-8 [&:not([class*='size-'])]:size-4"
					/>
				))
			}
		</div>

		<a
			class="flex max-w-fit items-center gap-1.5 rounded-full bg-surface px-3 py-1.5 text-sm text-surface-foreground shadow-2xs ring ring-border-muted transition-all hover:-translate-y-0.5 hover:shadow-md focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
			href={localizePath(locale, centerPath)}><span>{t("card.details")}</span></a
		>
	</div>
</article>
