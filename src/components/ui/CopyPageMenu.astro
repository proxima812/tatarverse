	deepseek: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path fill="#4D6BFE" d="M23.748 4.482c-.254-.124-.364.113-.512.234-.051.039-.094.09-.137.136-.372.397-.806.657-1.373.626-.829-.046-1.537.214-2.163.848-.133-.782-.575-1.248-1.247-1.548-.352-.156-.708-.311-.955-.65-.172-.241-.219-.51-.305-.774-.055-.16-.11-.323-.293-.35-.2-.031-.278.136-.356.276-.313.572-.434 1.202-.422 1.84.027 1.436.633 2.58 1.838 3.393.137.093.172.187.129.323-.082.28-.18.552-.266.833-.055.179-.137.217-.329.14a5.526 5.526 0 0 1-1.736-1.18c-.857-.828-1.631-1.742-2.597-2.458a11.365 11.365 0 0 0-.689-.471c-.985-.957.13-1.743.388-1.836.27-.098.093-.432-.779-.428-.872.004-1.67.295-2.687.684a3.055 3.055 0 0 1-.465.137 9.597 9.597 0 0 0-2.883-.102c-1.885.21-3.39 1.102-4.497 2.623C.082 8.606-.231 10.684.152 12.85c.403 2.284 1.569 4.175 3.36 5.653 1.858 1.533 3.997 2.284 6.438 2.14 1.482-.085 3.133-.284 4.994-1.86.47.234.962.327 1.78.397.63.059 1.236-.03 1.705-.128.735-.156.684-.837.419-.961-2.155-1.004-1.682-.595-2.113-.926 1.096-1.296 2.746-2.642 3.392-7.003.05-.347.007-.565 0-.845-.004-.17.035-.237.23-.256a4.173 4.173 0 0 0 1.545-.475c1.396-.763 1.96-2.015 2.093-3.517.02-.23-.004-.467-.247-.588zM11.581 18c-2.089-1.642-3.102-2.183-3.52-2.16-.392.024-.321.471-.235.763.09.288.207.486.371.739.114.167.192.416-.113.603-.673.416-1.842-.14-1.897-.167-1.361-.802-2.5-1.86-3.301-3.307-.774-1.393-1.224-2.887-1.298-4.482-.02-.386.093-.522.477-.592a4.696 4.696 0 0 1 1.529-.039c2.132.312 3.946 1.265 5.468 2.774.868.86 1.525 1.887 2.202 2.891.72 1.066 1.494 2.082 2.48 2.914.348.292.625.514.891.677-.802.09-2.14.11-3.054-.614zm1-6.44a.306.306 0 0 1 .415-.287.302.302 0 0 1 .2.288.306.306 0 0 1-.31.307.303.303 0 0 1-.304-.308zm3.11 1.596c-.2.081-.399.151-.59.16a1.245 1.245 0 0 1-.798-.254c-.274-.23-.47-.358-.552-.758a1.73 1.73 0 0 1 .016-.588c.07-.327-.008-.537-.239-.727-.187-.156-.426-.199-.688-.199a.559.559 0 0 1-.254-.078.253.253 0 0 1-.114-.358c.028-.054.16-.186.192-.21.356-.202.767-.136 1.146.016.352.144.618.408 1.001.782.391.451.462.576.685.914.176.265.336.537.445.848.067.195-.019.354-.25.452z"/></svg>`,
	t3: `<svg viewBox="0 0 258 199" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M165.735 25.0701L188.947 0.972412H0.465994V25.0701H165.735Z" fill="currentColor"/><path d="M163.981 96.3239L254.022 3.68314L221.206 3.68295L145.617 80.7609L163.981 96.3239Z" fill="currentColor"/><path d="M233.658 131.418C233.658 155.075 214.48 174.254 190.823 174.254C171.715 174.254 155.513 161.738 150 144.439L146.625 133.848L127.329 153.143L129.092 157.336C139.215 181.421 163.034 198.354 190.823 198.354C227.791 198.354 257.759 168.386 257.759 131.418C257.759 106.937 244.399 85.7396 224.956 74.0905L220.395 71.3582L202.727 89.2528L210.788 93.5083C224.403 100.696 233.658 114.981 233.658 131.418Z" fill="currentColor"/><path fill-rule="evenodd" clip-rule="evenodd" d="M88.2625 192.669L88.2626 45.6459H64.1648L64.1648 192.669H88.2625Z" fill="currentColor"/></svg>`,
} as const;

const aiPlatforms = [
	{ name: "ChatGPT", base: "https://chatgpt.com", svg: svglIcons.chatgpt },
	{ name: "Claude", base: "https://claude.ai/new", svg: svglIcons.claude },
	{ name: "Gemini", base: "https://gemini.google.com/app", svg: svglIcons.gemini },

	{ name: "Grok", base: "https://grok.com", svg: svglIcons.grok },

	{
		name: "HuggingChat",
		base: "https://huggingface.co/chat",
		svg: svglIcons.huggingchat,
	},
	{ name: "DeepSeek", base: "https://chat.deepseek.com", svg: svglIcons.deepseek },

	{ name: "T3 Chat", base: "https://t3.chat", svg: svglIcons.t3 },
] as const;
---

<div class={cn("relative inline-flex", className)} data-copy-page-menu>
	<div class="group relative flex rounded-lg bg-muted">
		<!-- Copy Page button -->
		<button
			type="button"
			class="inline-flex text-sm size-9 items-center gap-1.5 rounded-l-lg pl-2.5 pr-2.5 text-[0.8rem] font-medium text-foreground transition-colors hover:bg-border/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
			data-copy-btn
			aria-label={t("copy.copyPageUrl")}
		>
			<!-- default: copy icon -->
			<svg
				data-icon-copy
				viewBox="0 0 24 24"
				class="size-3.5 shrink-0"
				fill="none"
				stroke="currentColor"
				stroke-width="1.8"
			>
				<rect x="8" y="7" width="12" height="12" rx="3"></rect>
				<path d="M16 7V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h1"></path>
			</svg>
			<!-- copied: check icon (hidden by default) -->
			<svg
				data-icon-check
				viewBox="0 0 24 24"
				class="hidden size-3.5 shrink-0 text-muted-foreground"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
			>
				<path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"></path>
			</svg>
		</button>

		<!-- Separator -->
		<span
			class="pointer-events-none absolute top-1 right-9 z-0 h-7 w-px bg-foreground/5"
			aria-hidden="true"></span>

		<!-- Chevron / dropdown trigger -->
		<button
			type="button"
			class="inline-flex size-9 shrink-0 items-center justify-center rounded-r-lg text-foreground transition-colors hover:bg-border/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
			aria-haspopup="menu"
			aria-expanded="false"
			aria-controls="copy-page-dropdown"
			aria-label={t("copy.moreOptions")}
			data-chevron-btn
		>
			<svg
				viewBox="0 0 20 20"
				class="size-3.5 transition-transform duration-150"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				data-chevron-icon
			>
				<path d="m5 7 5 5 5-5" stroke-linecap="round" stroke-linejoin="round"></path>
			</svg>
		</button>

		<!-- Dropdown panel -->
		<div
			id="copy-page-dropdown"
			role="menu"
			aria-label={t("copy.openPageIn")}
			class="absolute right-0 top-[calc(100%+0.375rem)] z-50 hidden max-h-[min(70vh,30rem)] min-w-[220px] overflow-y-auto rounded-lg border border-border bg-surface p-1 shadow-md"
			data-dropdown
		>
			{
				aiPlatforms.map((platform) => (
					<a
						href="#"
						role="menuitem"
						target="_blank"
						rel="noopener noreferrer"
						class="flex w-full items-center gap-2.5 rounded-md px-2.5 py-1.5 text-sm text-foreground hover:bg-muted focus-visible:outline-none focus-visible:bg-muted"
						data-ai-platform
						data-prompt-base={platform.base}
					>
						<span
							class="size-4 shrink-0 text-muted-foreground [&_svg]:size-full"
							aria-hidden="true"
							set:html={platform.svg}
						/>
						{t("copy.openInPlatform", { name: platform.name }, `Open in ${platform.name}`)}
					</a>
				))
			}
		</div>
	</div>
</div>

<script>
	const PROMPT_TEXT = (url: string) =>
		`I'm looking at this page: ${url}. Help me understand it. Be ready to explain concepts, give examples, or answer any questions about it. It can also help you find more information on the Internet and in other sources.`;

	function getPromptUrl(base: string, url: string) {
		const target = new URL(base);
		target.searchParams.set("q", PROMPT_TEXT(url));
		return target.toString();
	}

	document.querySelectorAll("[data-copy-page-menu]").forEach((root) => {
		const copyBtn = root.querySelector<HTMLButtonElement>("[data-copy-btn]");
		const chevronBtn = root.querySelector<HTMLButtonElement>("[data-chevron-btn]");
		const dropdown = root.querySelector<HTMLDivElement>("[data-dropdown]");
		const iconCopy = root.querySelector<SVGElement>("[data-icon-copy]");
		const iconCheck = root.querySelector<SVGElement>("[data-icon-check]");

		if (!copyBtn || !chevronBtn || !dropdown) return;

		// --- Copy button ---
		let resetTimer: ReturnType<typeof setTimeout> | null = null;

		copyBtn.addEventListener("click", async () => {
			await navigator.clipboard.writeText(window.location.href).catch(() => {});

			iconCopy?.classList.add("hidden");
			iconCheck?.classList.remove("hidden");

			if (resetTimer) clearTimeout(resetTimer);
			resetTimer = setTimeout(() => {
				iconCopy?.classList.remove("hidden");
				iconCheck?.classList.add("hidden");
			}, 2000);
		});

		// --- Dropdown toggle ---
		const setOpen = (open: boolean) => {
			dropdown.classList.toggle("hidden", !open);
			chevronBtn.setAttribute("aria-expanded", String(open));
			const chevronIcon = chevronBtn.querySelector<SVGElement>("[data-chevron-icon]");
			if (chevronIcon) {
				chevronIcon.style.transform = open ? "rotate(180deg)" : "";
			}
		};

		chevronBtn.addEventListener("click", (e) => {
			e.stopPropagation();
			setOpen(dropdown.classList.contains("hidden"));
		});

		document.addEventListener("click", (e) => {
			if (e.target instanceof Node && !root.contains(e.target)) {
				setOpen(false);
			}
		});

		chevronBtn.addEventListener("keydown", (e) => {
			if (e.key === "Escape") setOpen(false);
			if (e.key === "ArrowDown" && !dropdown.classList.contains("hidden")) {
				e.preventDefault();
				(dropdown.querySelector("[role=menuitem]") as HTMLElement)?.focus();
			}
		});

		// --- Populate dropdown hrefs ---
		const url = window.location.href;

		root.querySelectorAll<HTMLAnchorElement>("[data-ai-platform]").forEach((item) => {
			const base = item.dataset.promptBase;
			if (base) item.href = getPromptUrl(base, url);
		});

		// --- Keyboard nav within dropdown ---
		const menuItems = Array.from(
			dropdown.querySelectorAll<HTMLAnchorElement>("[role=menuitem]"),
		);
		menuItems.forEach((item, i) => {
			item.addEventListener("keydown", (e) => {
				if (e.key === "Escape") {
					setOpen(false);
					chevronBtn.focus();
				} else if (e.key === "ArrowDown") {
					e.preventDefault();
					menuItems[(i + 1) % menuItems.length]?.focus();
				} else if (e.key === "ArrowUp") {
					e.preventDefault();
					menuItems[(i - 1 + menuItems.length) % menuItems.length]?.focus();
				}
			});
		});
	});
</script>
