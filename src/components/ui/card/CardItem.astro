---
import { countryFlagsByRu, getCountryLabel, getCountryLabels } from "@/data/worldCountries";
import { getLocaleFromUrl, localizePath } from "@/i18n";
import { getCenterPath } from "@/utils/centers";
import { Icon } from "astro-icon/components";

type IconName = "tt" | "qt" | "bs";
type Category = "Татарский" | "Татаро-Башкирский" | "Башкирский" | "Крымотатарский";
const categoryIconMap: Record<Category, IconName[]> = {
	Татарский: ["tt"],
	"Татаро-Башкирский": ["tt", "bs"],
	Башкирский: ["bs"],
	Крымотатарский: ["qt"],
};
interface Location {
	flag?: string;
	city?: string;
	country?: string;
}

interface Props {
	id: string;
	routeId?: string;
	title?: string;
	summary?: string;
	type?: string;
	category?: string;
	location?: Location;
	region?: string;
}

const { id, routeId, title, summary, type, category, location, region } = Astro.props as Props;
const locale = getLocaleFromUrl(Astro.url);
const centerPath = getCenterPath(routeId ?? id);

const NO_DATA = "Нет данных.";
const cleanCity = location?.city && location.city !== NO_DATA ? location.city : undefined;
const cleanCountry =
	location?.country && location.country !== NO_DATA ? location.country : undefined;
const cleanFlag =
	location?.flag && location.flag !== NO_DATA
		? location.flag
		: cleanCountry
			? countryFlagsByRu[cleanCountry]
			: undefined;
const displayCountry = cleanCountry ? getCountryLabel(cleanCountry, locale) : undefined;
const countryKey = cleanCountry ?? "Прочее";
const countryLabels = cleanCountry ? getCountryLabels(cleanCountry) : undefined;
const displayTitle = title ?? "—";
const displayLocation =
	cleanFlag || cleanCity || displayCountry
		? { flag: cleanFlag, city: cleanCity, country: displayCountry, countryLabels }
		: null;

const icons = categoryIconMap[category as Category] ?? [];
const hasIcons = icons.length > 0;
const truncate = (value?: string, max = 23) => {
	if (!value) return "";
	const v = value.trim();
	return v.length > max ? v.slice(0, max).trimEnd() + "…" : v;
};
---

<a
	data-type={type ?? ""}
	data-category={category ?? ""}
	data-country={countryKey}
	data-title={displayTitle}
	data-summary={summary ?? ""}
	data-city={cleanCity ?? ""}
	data-region={region ?? ""}
	href={localizePath(locale, centerPath)}
	class="block min-w-0 rounded-4xl corner-squircle text-surface-foreground no-underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
>
	<article
		class="flex overflow-hidden rounded-4xl corner-squircle bg-muted p-5 shadow-2xs ring ring-depth-100/40 transition duration-500 ease-out sm:p-6 flex-col justify-between"
	>
		<div class="flex min-w-0 flex-wrap items-center gap-x-2 gap-y-1 text-surface-foreground">
			{
				hasIcons && (
					<div data-card-section="icons" class="flex shrink-0 gap-0.5">
						{icons.map((name) => (
							<Icon
								name={name}
								class="pointer-events-none size-7 shrink-0 [&:not([class*='size-'])]:size-4"
							/>
						))}
					</div>
				)
			}
			{
				hasIcons && displayLocation && (
					<span aria-hidden="true" class="text-border">
						|
					</span>
				)
			}
			{
				displayLocation && (
					<div
						data-card-section="location"
						class="flex min-w-0 items-center gap-1.5 text-xs text-muted-foreground"
					>
						{displayLocation.flag && (
							<span class="shrink-0 text-base leading-none">{displayLocation.flag}</span>
						)}
						{displayLocation.city && <span>{truncate(displayLocation.city.trim(), 12)}</span>}
						{displayLocation.city && displayLocation.countryLabels && (
							<span aria-hidden="true">&#10625;</span>
						)}
						{displayLocation.countryLabels && (
							<span
								data-country-label={cleanCountry}
								data-country-labels={JSON.stringify(displayLocation.countryLabels)}
							>
								{displayLocation.country}
							</span>
						)}
					</div>
				)
			}
			{
				(hasIcons || displayLocation) && (
					<span aria-hidden="true" class="text-border">
						|
					</span>
				)
			}
			<h2
				data-card-section="title"
				class="min-w-0 flex-1 wrap-anywhere font-bold line-clamp-1 leading-snug tracking-tight text-surface-foreground"
			>
				{displayTitle}
			</h2>
		</div>
	</article>
</a>
