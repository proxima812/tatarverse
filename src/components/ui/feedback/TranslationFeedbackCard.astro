---
// Карточка обратной связи: показывает текст и ссылку в Telegram для исправлений.
import { getLocaleFromUrl, useTranslations } from "@/i18n";
import { Icon } from "astro-icon/components";

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<section class="flex gap-1.5 justify-between flex-wrap">
	<div
		id="errors"
		class="max-w-fit flex gap-1.5 sm:items-center items-start text-sm font-medium bg-destructive/10 text-destructive px-3 py-1.5 rounded-md"
	>
		<Icon name="mdi:warning" class="shrink-0 inline" />
		<span>{t("feedback.text")}</span>
	</div>
	<a
		href="https://t.me/ulu_er/8"
		target="_blank"
		rel="noopener noreferrer"
		class="max-w-fit hover:bg-subtle hover:text-foreground transition-colors ease-linear ring-1 ring-border-muted flex gap-1.5 items-center text-sm font-medium bg-surface text-primary px-3 py-1.5 rounded-md shadow-2xs"
	>
		<Icon name="mdi:telegram" />
		<span>{t("feedback.link")}</span>
	</a>
</section>
