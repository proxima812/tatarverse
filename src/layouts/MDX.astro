---
import { BackButton, Container } from "@/components";
import { getLocaleFromUrl, useTranslations } from "@/i18n";
import { formatContentDateTime, getContentDates } from "@/utils/contentDates";
import Layout from "./Layout.astro";

interface Frontmatter {
	title?: string;
	description?: string;
	[key: string]: unknown;
}

interface Props {
	frontmatter: Frontmatter;
	file?: string;
}

const { frontmatter, file } = Astro.props as Props;
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const { publishedDate, modifiedDate } = getContentDates({
	pubDate: frontmatter.pubDate as Date | string | undefined,
	filePath: file,
});
const publishedLabel = formatContentDateTime(publishedDate, locale);
const modifiedLabel = formatContentDateTime(modifiedDate, locale);
---

<Layout
	{...frontmatter}
	type="article"
	datePublished={publishedDate}
	dateModified={modifiedDate}
>
	<Container container class="max-w-5xl">
		<BackButton href="/" variant="outline" label="Назад" labelKey="nav.back" />
		<div class="my-12 pl-6">
			<span class="text-xs text-primary/40 mb-4 block">
				от {frontmatter.updateInfo}
			</span>
			<h1 class="text-4xl font-bold tracking-tight">{frontmatter.title}</h1>
		</div>

		<main
			class="prose max-w-none rounded-2xl border border-border-muted bg-surface p-8 shadow-2xs ring ring-depth-100/40"
		>
			<slot />
			{
				(publishedLabel || modifiedLabel) && (
					<footer class="mt-10 border-t border-border-muted pt-4 text-[0.68rem] leading-5 text-muted-foreground/60">
						{publishedLabel && (
							<time datetime={publishedDate?.toISOString()}>
								{t("content.published")}: {publishedLabel}
							</time>
						)}
						{publishedLabel && modifiedLabel && <span aria-hidden="true"> · </span>}
						{modifiedLabel && (
							<time datetime={modifiedDate?.toISOString()}>
								{t("content.updated")}: {modifiedLabel}
							</time>
						)}
					</footer>
				)
			}
		</main>
	</Container>
</Layout>
