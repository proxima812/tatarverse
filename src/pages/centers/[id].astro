---
import {
	ButtonLink,
	CardItem,
	CenterPagination,
	CopyPageMenu,
	markdownComponents,
	TranslationFeedbackCard,
} from "@/components";
import SkipNode from "@/components/markdown/SkipNode.astro";
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { getCollection, render, type CollectionEntry } from "astro:content";

import { getCountryGradient, getCountryLabel } from "@/data/worldCountries";
import { getLocaleFromUrl, localizePath, useTranslations } from "@/i18n";
import { createCenterRouteIdMap, getCenterPath } from "@/utils/centers";

export async function getStaticPaths() {
	const entries = await getCollection("centers");
	const routeIds = createCenterRouteIdMap(entries);

	return entries.map((entry) => ({
		params: { id: routeIds.get(entry.id) ?? entry.id },
		props: { entry },
	}));
}

interface Props {
	entry: CollectionEntry<"centers">;
	localizedEntry?: CollectionEntry<"centersEn">;
}

const { entry, localizedEntry } = Astro.props as Props;
const contentEntry = localizedEntry ?? entry;
const data = contentEntry.data;
const { Content } = await render(contentEntry);
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const centerEntries = (await getCollection("centers")).sort((a, b) => {
	return (
		(b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0) -
		(a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0)
	);
});
const routeIds = createCenterRouteIdMap(centerEntries);

const clean = (value?: string | null) => {
	if (!value) return null;
	const normalized = value.trim();
	return normalized.length ? normalized : null;
};

const title = clean(data.title) ?? t("detail.fallbackTitle");
const summary = clean(data.summary);
const country = clean(data.location?.country);
const city = clean(data.location?.city);
const flag = clean(data.location?.flag);
const region = clean(data.location?.region);
const type = clean(data.type);
const category = clean(data.category);
const rawPubDate = clean(data.pubDate);
const routeId = routeIds.get(entry.id) ?? entry.id;
const canonicalURL = localizePath(locale, getCenterPath(routeId));
const githubSourcePath = localizedEntry
	? `src/data/centers_i18n/${locale}/${localizedEntry.id}.mdx`
	: `src/data/centers_formatted/${entry.id}.mdx`;
const currentIndex = centerEntries.findIndex((centerEntry) => centerEntry.id === entry.id);
const previousEntry = currentIndex > 0 ? centerEntries[currentIndex - 1] : null;
const nextEntry =
	currentIndex >= 0 && currentIndex < centerEntries.length - 1
		? centerEntries[currentIndex + 1]
		: null;

const placeLine = [flag, country].filter(Boolean).join(" ");
const cityLine = city ?? null;
const formattedDate = rawPubDate
	? new Date(rawPubDate).toLocaleDateString(locale, {
			day: "numeric",
			month: "long",
			year: "numeric",
			timeZone: "Asia/Almaty",
		})
	: null;

const sourceUrl = clean(data.source);
const sourceLabel = (() => {
	if (!sourceUrl) return null;
	try {
		return new URL(sourceUrl).hostname.replace(/^www\./, "");
	} catch {
		return sourceUrl;
	}
})();

const facts = [
	placeLine
		? {
				label: t("detail.country"),
				value: placeLine,
				icon: "mdi:earth",
			}
		: null,
	cityLine
		? {
				label: t("detail.city"),
				value: cityLine,
				icon: "mdi:city-variant-outline",
			}
		: null,
	region
		? {
				label: t("detail.region"),
				value: region,
				icon: "mdi:map-marker-radius-outline",
			}
		: null,
	formattedDate
		? {
				label: t("detail.updated"),
				value: formattedDate,
				icon: "mdi:calendar-outline",
			}
		: null,
].filter(Boolean);

const pageDescription = summary ?? undefined;

// Шапка: бейджи категории/типа и ненавязчивый акцент по флагу страны.
const headerBadges = [category, type].filter((value): value is string => Boolean(value));
const localizedCountry = country ? getCountryLabel(country, locale) : null;
const countryGradient = getCountryGradient(country ?? undefined);

// Связанные центры: сперва из той же страны, иначе той же категории (по ru-данным
// для стабильного совпадения), с локализованным выводом карточек.
const ruCountry = clean(entry.data.location?.country);
const ruCategory = clean(entry.data.category);
const relatedIds = centerEntries
	.filter((centerEntry) => centerEntry.id !== entry.id)
	.filter((centerEntry) =>
		ruCountry
			? centerEntry.data.location?.country === ruCountry
			: ruCategory
				? centerEntry.data.category === ruCategory
				: false,
	)
	.slice(0, 6)
	.map((centerEntry) => centerEntry.id);

const localeEntries = locale === "en" ? await getCollection("centersEn") : centerEntries;
const localeEntryById = new Map(
	localeEntries.map((centerEntry) => [centerEntry.id, centerEntry]),
);
const relatedEntries = relatedIds
	.map((id) => localeEntryById.get(id) ?? centerEntries.find((e) => e.id === id))
	.filter((centerEntry): centerEntry is NonNullable<typeof centerEntry> =>
		Boolean(centerEntry),
	);
const relatedTitle = ruCountry
	? t("detail.related", { country: localizedCountry ?? country ?? "" })
	: t("detail.relatedCategory");

// Структурированные данные для поисковиков (каталог организаций).
const jsonLd = {
	"@context": "https://schema.org",
	"@type": "Organization",
	name: title,
	...(summary ? { description: summary } : {}),
	url: sourceUrl ?? canonicalURL,
	...(country || city
		? {
				address: {
					"@type": "PostalAddress",
					...(country ? { addressCountry: country } : {}),
					...(region ? { addressRegion: region } : {}),
					...(city ? { addressLocality: city } : {}),
				},
			}
		: {}),
};
---

<Layout title={title} description={pageDescription} type="article" canonicalURL={canonicalURL}>
	<article class="flex flex-col gap-10 max-w-5xl mx-auto">
		<nav class="flex justify-between sm:flex-nowrap flex-wrap items-center">
			<ButtonLink
				href={localizePath(locale, "/centers")}
				label="Все центры"
				labelKey="nav.allCenters"
				variant="outline"
				icon="tabler:arrow-back-up"
			/>
			<div class="sm:order-0 order-3 sm:mt-0 mt-3 flex w-full justify-between sm:w-auto">
				<ButtonLink
					href="#errors"
					label="Нашли ошибку?"
					labelKey="nav.mistake"
					variant="ghost"
					icon="tabler:face-id-error"
				/>
				<ButtonLink
					target="_blank"
					href={`https://github.com/proxima812/tatarverse/blob/main/${githubSourcePath}`}
					label="Править на GitHub"
					labelKey="nav.editOnGithub"
					variant="ghost"
					icon="mdi:github"
				/>
			</div>
			<CopyPageMenu />
		</nav>

		<div
			class="h-px w-[calc(100%-180px)] mx-auto bg-linear-to-r from-transparent via-border to-transparent"
		>
		</div>

		<header
			class="relative mx-auto flex max-w-4xl flex-col items-center gap-4 overflow-hidden text-center"
		>
			<!-- {
				countryGradient && (
					<span
						aria-hidden="true"
						class="pointer-events-none absolute -top-16 left-1/2 -z-10 h-40 w-[28rem] max-w-full -translate-x-1/2 opacity-[0.12] blur-2xl"
						style={`background-image:${countryGradient};`}
					/>
				)
			} -->
			{
				(headerBadges.length > 0 || localizedCountry) && (
					<div class="flex flex-wrap items-center justify-center gap-2 text-xs text-muted-foreground">
						{localizedCountry && (
							<span class="inline-flex items-center gap-1.5 rounded-full bg-surface px-3 py-1 font-medium ring ring-depth-100/60">
								{flag && <span class="text-sm leading-none">{flag}</span>}
								{localizedCountry}
							</span>
						)}
						{headerBadges.map((badge) => (
							<span class="rounded-full bg-surface px-3 py-1 font-medium ring ring-depth-100/60">
								{badge}
							</span>
						))}
					</div>
				)
			}
			<h1
				class="text-3xl font-semibold leading-tight text-foreground text-balance sm:text-5xl"
			>
				{title}
			</h1>
			{
				summary && (
					<p class="max-w-3xl text-base leading-7 text-muted-foreground sm:text-lg">
						{summary}
					</p>
				)
			}
		</header>

		<div
			class="h-px w-[calc(100%-180px)] mx-auto bg-linear-to-r from-transparent via-border to-transparent"
		>
		</div>

		<main class="relative flex flex-col gap-6 lg:flex-row lg:items-start lg:gap-10 xl:gap-12">
			<div class="max-w-none prose">
				<Content components={{ ...markdownComponents, h1: SkipNode }} />
			</div>

			{
				facts.length > 0 && (
					<aside class="order-first h-fit w-full shrink-0 rounded-2xl corner-squircle bg-depth-100/30 p-5 shadow-2xs ring ring-depth-100/70 sm:p-6 lg:sticky lg:top-12 lg:order-2 lg:w-72">
						<span class="mb-4 flex items-center gap-2 text-sm font-semibold text-foreground">
							<Icon name="mdi:information-outline" class="h-4 w-4 text-muted-foreground" />
							<span>{t("detail.summary")}</span>
						</span>
						<dl class="space-y-4 text-sm text-muted-foreground">
							{facts &&
								facts.map((fact) => (
									<div>
										<dt class="mb-1 flex items-center gap-1.5 text-xs uppercase text-subtle-foreground">
											<Icon name={fact?.icon} class="h-3.5 w-3.5" />
											<span>{fact?.label}</span>
										</dt>
										<dd class="break-words text-foreground">{fact?.value}</dd>
									</div>
								))}
						</dl>
						<hr class="bg-primary/10 my-4" />
						<span class="mb-1 flex items-center gap-1.5 text-xs uppercase text-subtle-foreground">
							<Icon name="mdi:link" />
							{t("detail.source")}
						</span>
						{sourceUrl && (
							<a
								target="_blank"
								rel="nofollow noreferrer noopener"
								href={sourceUrl}
								class="break-words text-sm underline"
							>
								{sourceLabel}
							</a>
						)}
					</aside>
				)
			}
		</main>

		{
			relatedEntries.length > 0 && (
				<section class="flex flex-col gap-5">
					<h2 class="flex items-center gap-2 text-lg font-semibold text-foreground">
						<Icon name="mdi:compass-outline" class="h-5 w-5 text-muted-foreground" />
						{relatedTitle}
					</h2>
					<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
						{relatedEntries.map((relatedEntry) => (
							<CardItem
								id={relatedEntry.id}
								routeId={routeIds.get(relatedEntry.id) ?? relatedEntry.id}
								title={relatedEntry.data.title}
								summary={relatedEntry.data.summary}
								type={relatedEntry.data.type}
								category={relatedEntry.data.category}
								location={relatedEntry.data.location}
								region={relatedEntry.data.location?.region}
								pubDate={relatedEntry.data.pubDate}
							/>
						))}
					</div>
				</section>
			)
		}

		<CenterPagination
			previousEntry={previousEntry}
			nextEntry={nextEntry}
			routeIds={routeIds}
		/>

		<TranslationFeedbackCard />
	</article>
	<script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
</Layout>
