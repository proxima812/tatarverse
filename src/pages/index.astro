---
import { HomeHeroTitle, HomeLinks, WordMarquee } from "@/components";
import { getLocaleFromUrl, localizePath, useTranslations } from "@/i18n";
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
const centers = (await getCollection("centers")).length;
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const homeDescription =
	"ТБК — это татары, башкиры и крымские татары. tatarverse собирает культурные центры, сообщества и источники в одном каталоге с поиском и фильтрами по странам, городам, регионам и категориям.";
---

<Layout
	title="ТБК — татары, башкиры и крымские татары"
	description={homeDescription}
	keywords={[
		"ТБК",
		"татары",
		"башкиры",
		"крымские татары",
		"татарские центры",
		"башкирские центры",
		"крымскотатарские центры",
		"культурные центры",
	]}
>
	<main class="space-y-12">
		<div>
			<HomeHeroTitle />
		</div>
		<div>
			<HomeLinks />
		</div>
		<p class="text-primary/50 text-xs">
			<span>{t("home.intro.prefix")}</span>
			<a
				href={localizePath(locale, "/centers")}
				class="font-medium text-link underline decoration-link-decoration underline-offset-4 transition hover:decoration-link"
			>
				{t("home.intro.link", { count: centers })}
			</a>
			<span> {t("home.intro.suffix")}</span>
		</p>
		<div>
			<WordMarquee />
		</div>
	</main>

</Layout>
