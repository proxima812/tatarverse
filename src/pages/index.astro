---
import { HomeHeroTitle, HomeLinks, WordMarquee } from "@/components";
import { getLocaleFromUrl, localizePath, useTranslations } from "@/i18n";
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
const centers = (await getCollection("centers")).length;
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const homeDescription =
	"ТБК — это татары, башкиры и крымские татары. tatarverse собирает культурные центры, сообщества и источники в одном каталоге с поиском и фильтрами по странам, городам, регионам и категориям.";
---

<Layout
	title="ТБК — татары, башкиры и крымские татары"
	description={homeDescription}
	keywords={[
		"ТБК",
		"татары",
		"башкиры",
		"крымские татары",
		"татарские центры",
		"башкирские центры",
		"крымскотатарские центры",
		"культурные центры",
	]}
>
	<main data-home-reveal-root class="space-y-12">
		<div data-home-reveal>
			<HomeHeroTitle />
		</div>
		<div data-home-reveal>
			<HomeLinks />
		</div>
		<p data-home-reveal class="text-primary/50 text-xs">
			<span>{t("home.intro.prefix")}</span>
			<a
				href={localizePath(locale, "/centers")}
				class="font-medium text-link underline decoration-link-decoration underline-offset-4 transition hover:decoration-link"
			>
				{t("home.intro.link", { count: centers })}
			</a>
			<span> {t("home.intro.suffix")}</span>
		</p>
		<div data-home-reveal>
			<WordMarquee />
		</div>
	</main>

</Layout>

<script>
	import { animate, stagger } from "motion";

	const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
	const roots = document.querySelectorAll<HTMLElement>("[data-home-reveal-root]");

	for (const root of roots) {
		const items = root.querySelectorAll<HTMLElement>("[data-home-reveal]");

		if (prefersReducedMotion) {
			root.classList.add("is-home-motion-complete");
			continue;
		}

		root.classList.add("is-home-motion-ready");

		animate(
			items,
			{
				opacity: [0, 1],
				y: ["1rem", "0rem"],
				filter: ["blur(10px)", "blur(0px)"],
			},
			{
				delay: stagger(0.14, {
					ease: [0.22, 1, 0.36, 1],
					startDelay: 0.16,
				}),
				duration: 0.95,
				ease: [0.22, 1, 0.36, 1],
			},
		).then(() => {
			root.classList.remove("is-home-motion-ready");
			root.classList.add("is-home-motion-complete");
		});
	}
</script>

<style>
	[data-home-reveal] {
		transform-origin: 50% 100%;
		will-change: filter, opacity, transform;
	}

	.is-home-motion-ready [data-home-reveal] {
		opacity: 0;
		filter: blur(10px);
		transform: translateY(1rem);
	}

	.is-home-motion-complete [data-home-reveal] {
		opacity: 1;
		filter: blur(0);
		transform: translateY(0);
		will-change: auto;
	}

	@media (prefers-reduced-motion: reduce) {
		[data-home-reveal] {
			opacity: 1;
			filter: blur(0);
			transform: none;
			will-change: auto;
		}
	}
</style>
