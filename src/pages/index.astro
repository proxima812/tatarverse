---
import searchImageEn from "@/assets/1-en.png";
import searchImageRu from "@/assets/1-ru.png";
import { CatalogStats, HomeHeroTitle, HomeLinks, LIquidMetal } from "@/components";
import { getLocaleFromUrl, useTranslations } from "@/i18n";
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

const allCenters = await getCollection("centers");
const centers = allCenters.length;
const countriesCount = new Set(
	allCenters.map((center) => center.data.location?.country).filter(Boolean),
).size;
const regionsCount = new Set(
	allCenters.map((center) => center.data.location?.region).filter(Boolean),
).size;
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const searchImage = locale === "en" ? searchImageEn : searchImageRu;
---

<Layout
	title={t("home.meta.title")}
	description={t("home.meta.description")}
	keywords={[
		"ТБК",
		"татары",
		"башкиры",
		"крымские татары",
		"татарские центры",
		"башкирские центры",
		"крымскотатарские центры",
		"культурные центры",
		`${centers} центров`,
		`${countriesCount} стран`,
		`${regionsCount} регионов`,
	]}
>
	<main class="space-y-12">
		<LIquidMetal />

		<HomeHeroTitle />

		<div>
			<HomeLinks />
		</div>


		<div class="md:space-y-16 space-y-8 py-12 md:py-24">
      <section class="mx-auto flex max-w-3xl flex-col items-center gap-6 px-6 text-center">
        <CatalogStats count={centers} countries={countriesCount} regions={regionsCount} />
        <p class="max-w-2xl text-sm leading-6 text-muted-foreground sm:text-base">
          {t("home.stats.caption", { centers, countries: countriesCount, regions: regionsCount })}
        </p>
      </section>
			<section
				class="grid grid-cols-1 items-center overflow-hidden rounded-3xl bg-white shadow-2xl shadow-zinc-200 md:grid-cols-2"
			>
				<div class="order-2 space-y-6 px-6 py-10 sm:px-8 md:order-1 md:px-12 md:py-16">
					<h2 class="text-4xl font-bold tracking-tight">
						{t("home.search.title")}
					</h2>

					<p class="leading-7 text-muted-foreground">
						{t("home.search.text1")}
					</p>

					<p class="leading-7 text-muted-foreground">
						{t("home.search.text2")}
					</p>
				</div>

				<Image
					src={searchImage}
					alt={t("home.search.imageAlt")}
					class="order-1 w-full object-cover md:order-2 h-full"
				/>
			</section>

			<!-- <section class="rounded-2xl bg-white shadow-2xl shadow-zinc-200">lorem ipsum</section> -->

			<!-- <div>
				<WordMarquee />
			</div> -->
		</div>
	</main>
</Layout>
