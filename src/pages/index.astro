---
// Главная страница собирается из hero-заголовка, навигационных ссылок и бегущей плашки слов.
import WordMarquee from "@/components/WordMarquee.astro";
import HomeLinks from "@/components/HomeLinks.astro";
import HomeHeroTitle from "@/components/HomeHeroTitle.astro";
import { getLocaleFromUrl, localizePath, useTranslations } from "@/i18n";
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
const centers = (await getCollection("centers")).length;
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<Layout title="" description="">
	<main class="space-y-12">
		<HomeHeroTitle />
		<HomeLinks />
		<p class="text-primary/50 text-xs">
			<span>{t("home.intro.prefix")}</span>
			<a
				href={localizePath(locale, "/list")}
				class="font-medium text-link underline decoration-link-decoration underline-offset-4 transition hover:decoration-link"
			>
				{t("home.intro.link", { count: centers })}
			</a>
			<span> {t("home.intro.suffix")}</span>
		</p>
		<WordMarquee />
	</main>

	<!-- <QList /> -->
</Layout>
