---
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { getCollection, render, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
	const entries = await getCollection("centers");
	return entries.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

interface Props {
	entry: CollectionEntry<"centers">;
}

const { entry } = Astro.props;
const data = entry.data;
const { Content } = await render(entry);

const clean = (value?: string | null) => {
	if (!value) return null;
	const normalized = value.trim();
	return normalized.length ? normalized : null;
};

const title = clean(data.title) ?? "Центр";
const summary = clean(data.summary);
const country = clean(data.location?.country);
const city = clean(data.location?.city);
const flag = clean(data.location?.flag);
const rawPubDate = clean(data.pubDate);

const placeLine = [flag, country].filter(Boolean).join(" ");
const cityLine = city ?? null;
const formattedDate = rawPubDate
	? new Date(rawPubDate).toLocaleDateString("ru-RU", {
			day: "numeric",
			month: "long",
			year: "numeric",
		})
	: null;

const facts = [
	placeLine ? { label: "Страна", value: placeLine, icon: "mdi:earth" } : null,
	cityLine ? { label: "Город", value: cityLine, icon: "mdi:city-variant-outline" } : null,
	formattedDate
		? { label: "Обновление", value: formattedDate, icon: "mdi:calendar-outline" }
		: null,
].filter(Boolean);

const pageDescription = summary ?? undefined;
---

<Layout title={``} description={``}>
	<article class="flex flex-col gap-10">
		<nav>
			<a
				href="/list"
				class="inline-flex items-center gap-2 text-sm text-zinc-500 transition hover:text-zinc-900"
			>
				<Icon name="mdi:arrow-left" class="h-4 w-4" />
				Все центры
			</a>
		</nav>

		<section class="flex flex-col gap-4">
			{
				(placeLine || cityLine) && (
					<p class="text-sm font-medium text-zinc-500">
						{placeLine}
						{placeLine && cityLine ? " · " : ""}
						{cityLine}
					</p>
				)
			}

			<h1 class="max-w-4xl text-3xl font-semibold leading-tight text-zinc-950 sm:text-5xl">
				{title}
			</h1>

			{summary && <p class=" text-base leading-7 text-zinc-600 sm:text-lg">{summary}</p>}
		</section>

		<main class="prose prose-zinc">
			<Content />
		</main>

		{
			facts.length > 0 && (
				<aside class="lg:sticky lg:top-10">
					<div class="space-y-8">
						<section class="py-5">
							<h2 class="mb-4 flex items-center gap-2 text-sm font-semibold text-zinc-950">
								<Icon name="mdi:information-outline" class="h-4 w-4 text-zinc-500" />
								Кратко
							</h2>
							<dl class="space-y-4 text-sm text-zinc-600">
								{facts.map((fact) => (
									<div>
										<dt class="mb-1 flex items-center gap-1.5 text-xs uppercase text-zinc-400">
											<Icon name={fact.icon} class="h-3.5 w-3.5" />
											{fact.label}
										</dt>
										<dd class="text-zinc-700">{fact.value}</dd>
									</div>
								))}
							</dl>
						</section>
					</div>
				</aside>
			)
		}
	</article>
</Layout>
