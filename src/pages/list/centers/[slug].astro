---
// Страница детали центра: собирает контент, метаданные и блоки фактов.
import ButtonLink from "@/components/ui/ButtonLink.astro";
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { getCollection, render, type CollectionEntry } from "astro:content";

import TranslationFeedbackCard from "@/components/TranslationFeedbackCard.astro";
import { markdownComponents } from "@/components/markdown";
import CopyPageMenu from "@/components/ui/CopyPageMenu.astro";
import { getLocaleFromUrl, useTranslations } from "@/i18n";

export async function getStaticPaths() {
	const entries = await getCollection("centers");
	return entries.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

interface Props {
	entry: CollectionEntry<"centers">;
}

const { entry } = Astro.props as Props;
const data = entry.data;
const { Content } = await render(entry);
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const clean = (value?: string | null) => {
	if (!value) return null;
	const normalized = value.trim();
	return normalized.length ? normalized : null;
};

const title = clean(data.title) ?? t("detail.fallbackTitle");
const summary = clean(data.summary);
const country = clean(data.location?.country);
const city = clean(data.location?.city);
const flag = clean(data.location?.flag);
const rawPubDate = clean(data.pubDate);

const placeLine = [flag, country].filter(Boolean).join(" ");
const cityLine = city ?? null;
const formattedDate = rawPubDate
	? new Date(rawPubDate).toLocaleDateString(locale, {
			day: "numeric",
			month: "long",
			year: "numeric",
			timeZone: "Asia/Almaty",
		})
	: null;

const sourceUrl = clean(data.source);
const sourceLabel = (() => {
	if (!sourceUrl) return null;
	try {
		return new URL(sourceUrl).hostname.replace(/^www\./, "");
	} catch {
		return sourceUrl;
	}
})();

const facts = [
	placeLine
		? {
				label: t("detail.country"),
				labelKey: "detail.country",
				value: placeLine,
				icon: "mdi:earth",
			}
		: null,
	cityLine
		? {
				label: t("detail.city"),
				labelKey: "detail.city",
				value: cityLine,
				icon: "mdi:city-variant-outline",
			}
		: null,
	formattedDate
		? {
				label: t("detail.updated"),
				labelKey: "detail.updated",
				value: formattedDate,
				icon: "mdi:calendar-outline",
			}
		: null,
].filter(Boolean);

const pageDescription = summary ?? undefined;
---

<Layout title={`${title}`} description={`${pageDescription}`} type="article">
	<article class="flex flex-col gap-10 max-w-5xl mx-auto">
		<nav class="flex justify-between flex-wrap items-center">
			<ButtonLink
				href="/list"
				label="All centers"
				labelKey="nav.allCenters"
				variant="outline"
				icon="tabler:arrow-back-up"
			/>

			<div class="sm:order-0 order-3 sm:mt-0 mt-3">
				<ButtonLink
					href="#errors"
					label="Find a mistake?"
					labelKey="nav.mistake"
					variant="ghost"
					icon="tabler:face-id-error"
				/>
				<ButtonLink
					target="_blank"
					href={`https://github.com/proxima812/list-centers/blob/main/src/data/centers/${entry.id}.mdx`}
					label="Edit on GitHub"
					labelKey="nav.editOnGithub"
					variant="ghost"
					icon="mdi:github"
				/>
			</div>
			<CopyPageMenu />
		</nav>

		<div
			class="h-px w-[calc(100%-180px)] mx-auto bg-linear-to-r from-transparent via-border to-transparent"
		>
		</div>

		<h1
			class="max-w-4xl mx-auto text-center text-3xl font-semibold leading-tight text-foreground sm:text-5xl"
		>
			{title}
		</h1>

		{
			summary && (
				<p class="text-center max-w-4xl mx-auto text-base leading-7 text-muted-foreground sm:text-lg">
					{summary}
				</p>
			)
		}

		<div
			class="h-px w-[calc(100%-180px)] mx-auto bg-linear-to-r from-transparent via-border to-transparent"
		>
		</div>

		<main class="relative flex flex-col gap-6 lg:flex-row lg:items-start lg:gap-10 xl:gap-12">
			<section
				class="w-full rounded-2xl corner-squircle bg-background p-5 shadow-2xs ring ring-depth-100/70 sm:p-6 lg:order-1"
			>
				<div class="prose max-w-none">
					<!-- <Content /> -->
					<Content components={markdownComponents} />
				</div>
			</section>

			{
				facts.length > 0 && (
					<aside class="order-first h-fit w-full shrink-0 rounded-2xl corner-squircle bg-depth-100/30 p-5 shadow-2xs ring ring-depth-100/70 sm:p-6 lg:sticky lg:top-12 lg:order-2 lg:w-72">
						<span class="mb-4 flex items-center gap-2 text-sm font-semibold text-foreground">
							<Icon name="mdi:information-outline" class="h-4 w-4 text-muted-foreground" />
							<span>{t("detail.summary")}</span>
						</span>
						<dl class="space-y-4 text-sm text-muted-foreground">
							{facts &&
								facts.map((fact) => (
									<div>
										<dt class="mb-1 flex items-center gap-1.5 text-xs uppercase text-subtle-foreground">
											<Icon name={fact?.icon} class="h-3.5 w-3.5" />
											<span>{fact?.label}</span>
										</dt>
										<dd class="break-words text-foreground">{fact?.value}</dd>
									</div>
								))}
						</dl>
						<hr class="bg-primary/10 my-4" />
						<span class="mb-1 flex items-center gap-1.5 text-xs uppercase text-subtle-foreground">
							<Icon name="mdi:link" />
							Источник
						</span>
						{sourceUrl && (
							<a
								target="_blank"
								rel="nofollow noreferrer noopener"
								href={sourceUrl}
								class="break-words text-sm underline"
							>
								{sourceLabel}
							</a>
						)}
					</aside>
				)
			}
		</main>

		<TranslationFeedbackCard />
	</article>
</Layout>
