---
import BackButton from "@/components/navigation/BackButton.astro";
import Layout from "@/layouts/Layout.astro";
import { getCollection, render } from "astro:content";

const posts = await getCollection("posts");
const rendered = posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const title = "Посты";
const description =
	"Лента tatarverse: короткие заметки о центрах, культуре, языке и живом сообществе.";

const fullDateFormatter = new Intl.DateTimeFormat("ru-RU", {
	day: "numeric",
	month: "short",
	year: "numeric",
});

const stripMarkdown = (value: string) =>
	value
		.replace(/```[\s\S]*?```/g, "")
		.replace(/`([^`]+)`/g, "$1")
		.replace(/!\[([^\]]*)\]\([^)]+\)/g, "$1")
		.replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
		.replace(/[#>*_~|-]/g, "")
		.replace(/\s+/g, " ")
		.trim();

const getRelativeTime = (date: Date) => {
	const diffMs = Date.now() - date.getTime();
	const minute = 60000;
	const hour = 60 * minute;
	const day = 24 * hour;

	if (diffMs < hour) {
		return `${Math.max(1, Math.floor(diffMs / minute))} мин.`;
	}

	if (diffMs < day) {
		return `${Math.floor(diffMs / hour)} ч.`;
	}

	return `${Math.floor(diffMs / day)} дн.`;
};

const postsFeed = await Promise.all(
	rendered.map(async (post) => {
		const { Content } = await render(post);
		const plainText = stripMarkdown(post.body ?? post.data.description);

		return {
			Content,
			isLong: plainText.length > 200,
			pubDate: post.data.pubDate,
			relativeTime: getRelativeTime(post.data.pubDate),
			fullDate: fullDateFormatter.format(post.data.pubDate).replace(/\s?г\.$/, ""),
		};
	}),
);
---

<Layout
	title={title}
	description={description}
	keywords={["tatarverse", "посты", "лента", "сабантуй", "культура", "язык"]}
>
	<BackButton href="/" variant="outline" label="Назад" labelKey="nav.back" />
	<main class="mx-auto w-full max-w-2xl">
		<header class="space-y-3">
			<h1 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
				{title}
			</h1>
			<p class="text-sm leading-6 text-muted-foreground sm:text-base">
				{description}
			</p>
		</header>

		<section
			class="mt-6 divide-y divide-border-muted border-y border-border-muted"
			aria-label="Лента постов"
		>
			{
				postsFeed.map((post) => (
					<article class="py-5 sm:py-6">
						<header class="flex min-w-0 items-center gap-1.5 text-sm leading-5">
							<span class="font-semibold text-foreground">tatarverse</span>
							<span class="text-subtle-foreground" aria-hidden="true">
								|
							</span>
							<time
								class="text-muted-foreground"
								datetime={post.pubDate.toISOString()}
								title={post.fullDate}
							>
								{post.relativeTime}
							</time>
							<span class="text-subtle-foreground" aria-hidden="true">
								|
							</span>
							<time
								class="truncate text-muted-foreground"
								datetime={post.pubDate.toISOString()}
							>
								{post.fullDate}
							</time>
						</header>

						<div class="mt-2 text-depth-600 leading-relaxed">
							<div
								class:list={[
									"prose prose-sm max-w-none sm:prose-base prose-p:my-2 prose-blockquote:my-3 first:prose-p:mt-0 last:prose-p:mb-0",
									post.isLong && "line-clamp-4",
								]}
								data-post-text
							>
								<post.Content />
							</div>
							{post.isLong && (
								<button
									type="button"
									class="mt-1 inline-flex items-center gap-1 text-sm cursor-pointer font-medium text-muted-foreground transition hover:text-foreground focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring [&[aria-expanded='true']_svg]:rotate-180"
									data-post-toggle
									aria-expanded="false"
								>
									<span data-post-toggle-label>Развернуть</span>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
										class="size-4 transition-transform"
										aria-hidden="true"
									>
										<path d="m6 9 6 6 6-6" />
									</svg>
								</button>
							)}
						</div>
					</article>
				))
			}
		</section>
	</main>
</Layout>

<script>
	document.querySelectorAll<HTMLButtonElement>("[data-post-toggle]").forEach((toggle) => {
		const text = toggle.closest("article")?.querySelector<HTMLElement>("[data-post-text]");
		const label = toggle.querySelector<HTMLElement>("[data-post-toggle-label]");
		if (!text || !label) return;

		toggle.addEventListener("click", () => {
			const expanded = toggle.getAttribute("aria-expanded") === "true";

			text.classList.toggle("line-clamp-4", expanded);
			toggle.setAttribute("aria-expanded", String(!expanded));
			label.textContent = expanded ? "Развернуть" : "Свернуть";
		});
	});
</script>
