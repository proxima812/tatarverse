---
import BackButton from "@/components/navigation/BackButton.astro";
import PostCard from "@/components/posts/PostCard.astro";
import Layout from "@/layouts/Layout.astro";
import { formatContentDateTime, getContentDates } from "@/utils/contentDates";
import { getCollection, render } from "astro:content";

const posts = await getCollection("posts");
const rendered = posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const title = "Посты";
const description =
	"Лента tatarverse: короткие заметки о центрах, культуре, языке и живом сообществе.";

const fullDateFormatter = new Intl.DateTimeFormat("ru-RU", {
	day: "numeric",
	month: "short",
	year: "numeric",
});

const stripMarkdown = (value: string) =>
	value
		.replace(/```[\s\S]*?```/g, "")
		.replace(/`([^`]+)`/g, "$1")
		.replace(/!\[([^\]]*)\]\([^)]+\)/g, "$1")
		.replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
		.replace(/[#>*_~|-]/g, "")
		.replace(/\s+/g, " ")
		.trim();

const getPostAnchor = (id: string) => id.replace(/\/$/, "");

const getRelativeTime = (date: Date) => {
	const diffMs = Date.now() - date.getTime();
	const minute = 60000;
	const hour = 60 * minute;
	const day = 24 * hour;

	if (diffMs < hour) {
		return `${Math.max(1, Math.floor(diffMs / minute))} мин.`;
	}

	if (diffMs < day) {
		return `${Math.floor(diffMs / hour)} ч.`;
	}

	return `${Math.floor(diffMs / day)} дн.`;
};

const postsFeed = await Promise.all(
	rendered.map(async (post) => {
		const { Content } = await render(post);
		const plainText = stripMarkdown(post.body ?? post.data.description);
		const { publishedDate, modifiedDate } = getContentDates({
			pubDate: post.data.pubDate,
			filePath: post.filePath,
		});

		return {
			Content,
			id: getPostAnchor(post.id),
			title: post.data.title,
			description: post.data.description,
			author: post.data.author,
			isLong: plainText.length > 200,
			pubDate: post.data.pubDate,
			publishedDate,
			modifiedDate,
			relativeTime: getRelativeTime(post.data.pubDate),
			fullDate: fullDateFormatter.format(post.data.pubDate).replace(/\s?г\.$/, ""),
			publishedLabel: formatContentDateTime(publishedDate, "ru"),
			modifiedLabel: formatContentDateTime(modifiedDate, "ru"),
		};
	}),
);

const latestModifiedDate = postsFeed
	.map((post) => post.modifiedDate)
	.filter((date): date is Date => Boolean(date))
	.sort((a, b) => b.getTime() - a.getTime())[0];
---

<Layout
	title={title}
	description={description}
	keywords={["tatarverse", "посты", "лента", "сабантуй", "культура", "язык"]}
	rssURL="/posts/rss.xml"
	dateModified={latestModifiedDate}
>
	<BackButton href="/" variant="outline" label="Назад" labelKey="nav.back" />
	<main class="mx-auto w-full max-w-3xl">
		<header class="space-y-3">
			<h1 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
				{title}
			</h1>
			<p class="max-w-2xl text-sm leading-6 text-muted-foreground sm:text-base">
				{description}
			</p>
		</header>

		<section
			class="mt-6 grid gap-4 sm:mt-8 sm:gap-5"
			aria-label="Лента постов"
		>
			{
				postsFeed.map((post) => (
					<PostCard
						id={post.id}
						title={post.title}
						description={post.description}
						author={post.author}
						pubDate={post.pubDate}
						publishedDate={post.publishedDate}
						modifiedDate={post.modifiedDate}
						relativeTime={post.relativeTime}
						fullDate={post.fullDate}
						publishedLabel={post.publishedLabel}
						modifiedLabel={post.modifiedLabel}
						isLong={post.isLong}
					>
						<post.Content />
					</PostCard>
				))
			}
		</section>
	</main>
</Layout>
