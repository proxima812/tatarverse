---
import BackButton from "@/components/navigation/BackButton.astro";
import Layout from "@/layouts/Layout.astro";

const title = "#сабантуй";
const description =
	"Сабантуй в tatarverse: оставьте заявку на праздник в своём городе или стране, чтобы земляки и гости смогли найти его и присоединиться.";

const now = new Date();
const julyFirst = (year: number) => new Date(year, 6, 1, 0, 0, 0);
let sabantuyYear = now.getFullYear();
let sabantuyTarget = julyFirst(sabantuyYear);
if (sabantuyTarget.getTime() <= now.getTime()) {
	sabantuyYear += 1;
	sabantuyTarget = julyFirst(sabantuyYear);
}
const diffMs = Math.max(0, sabantuyTarget.getTime() - now.getTime());
const initialCountdown = {
	days: Math.floor(diffMs / 86400000),
	hours: Math.floor((diffMs % 86400000) / 3600000),
	minutes: Math.floor((diffMs % 3600000) / 60000),
	seconds: Math.floor((diffMs % 60000) / 1000),
};
const pad = (value: number) => String(value).padStart(2, "0");
const countdownUnits = [
	{ key: "days", label: "дней", value: initialCountdown.days },
	{ key: "hours", label: "часов", value: initialCountdown.hours },
	{ key: "minutes", label: "минут", value: initialCountdown.minutes },
	{ key: "seconds", label: "секунд", value: initialCountdown.seconds },
] as const;

const feedbackHref = "https://t.me/ulu_er/19";
---

<Layout
	title={title}
	description={description}
	keywords={["tatarverse", "сабантуй", "праздник", "культура", "татары"]}
>
<BackButton href="/" variant="outline" label="Назад" labelKey="nav.back" />
	<main class="mx-auto w-full max-w-2xl space-y-6">

		<header class="space-y-3">
			<h1 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
				{title}
			</h1>
		</header>

		<article
			class="corner-squircle relative overflow-hidden rounded-4xl bg-primary p-6 text-primary-foreground shadow-2xs ring ring-inset ring-white/10 sm:p-8"
		>
			<div
				class="pointer-events-none absolute -top-28 left-1/2 h-52 w-[120%] -translate-x-1/2 rounded-full bg-white/10 blur-3xl"
				aria-hidden="true"
			>
			</div>

			<div class="relative">
				<h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
					Сабантуй <span data-sabantuy-year>{sabantuyYear}</span>
				</h2>
				<p class="mt-2 text-sm font-medium text-white/60 sm:text-base">
					1 июля <span data-sabantuy-year>{sabantuyYear}</span> года
				</p>

				<div
					id="sabantuy-countdown"
					class="mt-8 flex items-start justify-between gap-1 sm:justify-start sm:gap-3"
					role="timer"
					aria-label={`До Сабантуя ${sabantuyYear} осталось`}
				>
					{
						countdownUnits.map((unit, index) => (
							<Fragment>
								<div class="min-w-0 text-center">
									<span
										data-countdown={unit.key}
										class="countdown-value block text-[clamp(2rem,8.5vw,3.75rem)] font-bold tabular-nums leading-none tracking-tight"
									>
										{unit.key === "days" ? unit.value : pad(unit.value)}
									</span>
									<span class="mt-2 block text-[0.65rem] font-medium uppercase tracking-wide text-white/50 sm:text-xs">
										{unit.label}
									</span>
								</div>
								{index < countdownUnits.length - 1 && (
									<span
										class="countdown-colon text-[clamp(2rem,8.5vw,3.75rem)] font-bold leading-none text-white/30"
										aria-hidden="true"
									>
										:
									</span>
								)}
							</Fragment>
						))
					}
				</div>

				<p class="mt-7 max-w-prose text-sm leading-6 text-white/80 sm:text-base">
					Проводите Сабантуй в своём городе или стране? Оставьте заявку — мы разместим ваш
					праздник в ленте, чтобы земляки и гости смогли найти его и присоединиться. Расскажите,
					где и когда, а мы поможем о нём узнать.
				</p>

				<a
					href={feedbackHref}
					target="_blank"
					rel="noreferrer noopener"
					class="group mt-6 inline-flex items-center gap-2 rounded-full bg-primary-foreground px-5 py-2.5 text-sm font-semibold text-primary no-underline transition hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
				>
					Оставить заявку
					<svg
						class="size-4 transition-transform duration-200 group-hover:translate-x-0.5"
						viewBox="0 0 16 16"
						fill="none"
						aria-hidden="true"
					>
						<path
							d="M3 8h10m0 0-4-4m4 4-4 4"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"
						/>
					</svg>
				</a>
			</div>
		</article>
	</main>
</Layout>

<style>
	.countdown-value {
		display: inline-block;
	}

	.countdown-value.is-ticking {
		animation: countdown-tick 0.45s cubic-bezier(0.16, 1, 0.3, 1);
	}

	@keyframes countdown-tick {
		0% {
			transform: translateY(45%);
			opacity: 0;
			filter: blur(1.5px);
		}
		100% {
			transform: translateY(0);
			opacity: 1;
			filter: blur(0);
		}
	}

	.countdown-colon {
		animation: colon-blink 2s ease-in-out infinite;
	}

	@keyframes colon-blink {
		50% {
			opacity: 0.35;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.countdown-value.is-ticking,
		.countdown-colon {
			animation: none;
		}
	}
</style>

<script>
	const countdown = document.getElementById("sabantuy-countdown");
	const yearEls = document.querySelectorAll<HTMLElement>("[data-sabantuy-year]");
	if (countdown) {
		const fields = {
			days: countdown.querySelector<HTMLElement>('[data-countdown="days"]'),
			hours: countdown.querySelector<HTMLElement>('[data-countdown="hours"]'),
			minutes: countdown.querySelector<HTMLElement>('[data-countdown="minutes"]'),
			seconds: countdown.querySelector<HTMLElement>('[data-countdown="seconds"]'),
		};
		const pad = (value: number) => String(value).padStart(2, "0");

		const tick = () => {
			const nowDate = new Date();
			const nowMs = nowDate.getTime();

			let targetYear = nowDate.getFullYear();
			let target = new Date(targetYear, 6, 1, 0, 0, 0).getTime();
			if (target <= nowMs) {
				targetYear += 1;
				target = new Date(targetYear, 6, 1, 0, 0, 0).getTime();
			}

			const yearText = String(targetYear);
			yearEls.forEach((el) => {
				if (el.textContent !== yearText) el.textContent = yearText;
			});

			const diff = Math.max(0, target - nowMs);
			const values = {
				days: Math.floor(diff / 86400000),
				hours: Math.floor((diff % 86400000) / 3600000),
				minutes: Math.floor((diff % 3600000) / 60000),
				seconds: Math.floor((diff % 60000) / 1000),
			};

			(Object.keys(fields) as Array<keyof typeof fields>).forEach((key) => {
				const el = fields[key];
				if (!el) return;
				const next = key === "days" ? String(values[key]) : pad(values[key]);
				if (el.textContent !== next) {
					el.textContent = next;
					el.classList.remove("is-ticking");
					void el.offsetWidth;
					el.classList.add("is-ticking");
				}
			});
		};

		tick();
		setInterval(tick, 1000);
	}
</script>
