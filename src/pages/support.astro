---
import BackButton from "@/components/navigation/BackButton.astro";
import Layout from "@/layouts/Layout.astro";

const title = "#поддержка";
const description =
	"Поддержка в tatarverse: витрина проектов татар, башкир и крымских татар — малый и средний бизнес, YouTube-каналы, сайты, Telegram-каналы и другие соцсети. Расскажите о своём проекте, чтобы его заметили.";

const categories = [
	"Малый и средний бизнес",
	"YouTube-каналы",
	"Сайты",
	"Telegram-каналы",
	"Соцсети",
];

const feedbackHref = "https://t.me/ulu_er/20";
---

<Layout
	title={title}
	description={description}
	keywords={[
		"tatarverse",
		"поддержка",
		"проекты",
		"бизнес",
		"татары",
		"башкиры",
		"крымские татары",
	]}
>
	<BackButton href="/" variant="outline" label="Назад" labelKey="nav.back" />
	<main class="mx-auto w-full max-w-2xl space-y-6">
		<header class="space-y-3">
			<h1 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
				{title}
			</h1>
		</header>

		<article
			class="corner-squircle relative overflow-hidden rounded-4xl bg-neutral-950 p-6 text-white shadow-2xs ring ring-inset ring-white/10 sm:p-8"
		>
			<div class="pointer-events-none absolute inset-0" aria-hidden="true">
				<div class="absolute -top-24 -left-20 size-72 rounded-full bg-amber-400/20 blur-3xl">
				</div>
				<div class="absolute top-1/3 -right-24 size-80 rounded-full bg-violet-500/20 blur-3xl">
				</div>
				<div class="absolute -bottom-28 left-1/3 size-72 rounded-full bg-cyan-400/15 blur-3xl">
				</div>
			</div>

			<div class="relative">
				<h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Поддержим своих</h2>
				<p class="mt-2 text-sm font-medium text-white/60 sm:text-base">
					Проекты татар, башкир и крымских татар
				</p>

				<ul class="mt-7 flex flex-wrap gap-2" aria-label="Категории проектов">
					{
						categories.map((category) => (
							<li class="inline-flex items-center rounded-full bg-white/10 px-3 py-1.5 text-xs font-semibold text-white/80 ring ring-inset ring-white/15 sm:text-sm">
								{category}
							</li>
						))
					}
				</ul>

				<p class="mt-7 max-w-prose text-sm leading-6 text-white/80 sm:text-base">
					Ведёте своё дело или проект? Небольшой бизнес, YouTube-канал, сайт, Telegram-канал
					или страницу в соцсетях — расскажите о нём. Мы разместим ссылку и описание, чтобы
					земляки и гости смогли вас найти и поддержать: подписаться, заказать, рассказать
					друзьям.
				</p>

				<a
					href={feedbackHref}
					target="_blank"
					rel="noreferrer noopener"
					class="group mt-6 inline-flex items-center gap-2 rounded-full bg-white px-5 py-2.5 text-sm font-semibold text-neutral-900 no-underline transition hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
				>
					Предложить проект
					<svg
						class="size-4 transition-transform duration-200 group-hover:translate-x-0.5"
						viewBox="0 0 16 16"
						fill="none"
						aria-hidden="true"
					>
						<path
							d="M3 8h10m0 0-4-4m4 4-4 4"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</svg>
				</a>
			</div>
		</article>
	</main>
	<section class="grid grid-cols-1 md:grid-cols-2 gap-5" aria-label="Проекты сообщества">
		{
			Array.from({ length: 4 }).map(() => (
				<article
					class="corner-squircle relative select-none overflow-hidden rounded-4xl bg-muted/50 p-5 opacity-60 ring ring-inset ring-border sm:p-6"
					aria-disabled="true"
				>
					<span class="inline-flex items-center rounded-full bg-foreground/10 px-3 py-1 text-[0.65rem] font-semibold uppercase tracking-wide text-muted-foreground">
						Скоро
					</span>
					<h3 class="mt-4 text-lg font-bold tracking-tight text-muted-foreground">Проект</h3>
					<p class="mt-1 text-sm text-muted-foreground/70">Название уточняется</p>
					<div class="mt-5 space-y-2" aria-hidden="true">
						<div class="h-2 w-3/4 rounded-full bg-foreground/10" />
						<div class="h-2 w-1/2 rounded-full bg-foreground/10" />
					</div>
				</article>
			))
		}
	</section>
</Layout>
