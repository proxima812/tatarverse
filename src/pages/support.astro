---
import BackButton from "@/components/navigation/BackButton.astro";
import Layout from "@/layouts/Layout.astro";
import { getProjectAsset, getProjectGradient } from "@/utils/projects";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";

const title = "#поддержка";
const description =
	"Поддержка в tatarverse: витрина проектов татар, башкир и крымских татар — малый и средний бизнес, YouTube-каналы, сайты, Telegram-каналы и другие соцсети. Расскажите о своём проекте, чтобы его заметили.";

const feedbackHref = "https://t.me/ulu_er/20";
const projects = (await getCollection("projects")).sort(
	(a, b) => a.data.sortOrder - b.data.sortOrder || a.data.title.localeCompare(b.data.title, "ru"),
);
const categories = Array.from(new Set(projects.map((project) => project.data.category)));

function getUrlLabel(url?: string) {
	if (!url) return null;

	try {
		return new URL(url).hostname.replace(/^www\./, "");
	} catch {
		return url;
	}
}

const projectCards = projects.map((project) => ({
	entry: project,
	detailHref: `/support/${project.id}/`,
	logo: getProjectAsset(project.data.logo),
	websiteLabel: getUrlLabel(project.data.website),
}));
---

<Layout
	title={title}
	description={description}
	keywords={[
		"tatarverse",
		"поддержка",
		"проекты",
		"бизнес",
		"татары",
		"башкиры",
		"крымские татары",
		"общепит",
		"Burger Point",
	]}
>
	<BackButton href="/" variant="outline" label="Назад" labelKey="nav.back" />
	<main class="mx-auto w-full max-w-2xl space-y-6">
		<header class="space-y-3">
			<h1 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
				{title}
			</h1>
		</header>

		<article
			class="corner-squircle relative overflow-hidden rounded-4xl bg-neutral-950 p-6 text-white shadow-2xs ring ring-inset ring-white/10 sm:p-8"
		>
			<div class="pointer-events-none absolute inset-0" aria-hidden="true">
				<div class="absolute -top-24 -left-20 size-72 rounded-full bg-amber-400/20 blur-3xl">
				</div>
				<div class="absolute top-1/3 -right-24 size-80 rounded-full bg-violet-500/20 blur-3xl">
				</div>
				<div class="absolute -bottom-28 left-1/3 size-72 rounded-full bg-cyan-400/15 blur-3xl">
				</div>
			</div>

			<div class="relative">
				<h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Поддержим своих</h2>
				<p class="mt-2 text-sm font-medium text-white/60 sm:text-base">
					Проекты татар, башкир и крымских татар
				</p>

				<p class="mt-7 max-w-prose text-sm leading-6 text-white/80 sm:text-base">
					Ведёте своё дело или проект? Небольшой бизнес, YouTube-канал, сайт, Telegram-канал
					или страницу в соцсетях — расскажите о нём. Мы разместим ссылку и описание, чтобы
					земляки и гости смогли вас найти и поддержать: подписаться, заказать, рассказать
					друзьям.
				</p>

				<a
					href={feedbackHref}
					target="_blank"
					rel="noreferrer noopener"
					class="group mt-6 inline-flex items-center gap-2 rounded-full bg-white px-5 py-2.5 text-sm font-semibold text-neutral-900 no-underline transition hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
				>
					Предложить проект
					<svg
						class="size-4 transition-transform duration-200 group-hover:translate-x-0.5"
						viewBox="0 0 16 16"
						fill="none"
						aria-hidden="true"
					>
						<path
							d="M3 8h10m0 0-4-4m4 4-4 4"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</svg>
				</a>
			</div>
		</article>
	</main>
	<section class="mx-auto w-full max-w-4xl space-y-6" aria-label="Проекты сообщества">
		<div
			id="project-filter"
			class="flex flex-wrap gap-2"
			role="group"
			aria-label="Фильтр проектов по категории"
		>
			<button
				type="button"
				class="filter-btn corner-squircle inline-flex cursor-pointer items-center rounded-full px-4 py-2 text-sm font-semibold ring ring-inset transition focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary bg-primary text-primary-foreground ring-primary"
				data-category=""
				aria-pressed="true"
			>
				Все
			</button>
			{
				categories.map((category) => (
					<button
						type="button"
						class="filter-btn corner-squircle inline-flex cursor-pointer items-center rounded-full px-4 py-2 text-sm font-semibold ring ring-inset transition focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary bg-surface text-muted-foreground ring-border-muted hover:bg-primary/5"
						data-category={category}
						aria-pressed="false"
					>
						{category}
					</button>
				))
			}
		</div>

		<div id="project-grid" class="grid grid-cols-1 gap-5 sm:grid-cols-2">
			{
				projectCards.map(({ entry: project, detailHref, logo, websiteLabel }) => (
					<article
						class="project-card corner-squircle flex h-full flex-col gap-4 rounded-4xl bg-surface p-5 text-surface-foreground shadow-2xs ring ring-border-muted sm:p-6"
						data-category={project.data.category}
					>
						<div class="flex min-w-0 items-start gap-4">
							{logo ? (
								<Image
									src={logo}
									alt={`Логотип ${project.data.title}`}
									class="size-16 shrink-0 rounded-2xl bg-white object-contain p-1 ring ring-border-muted"
									widths={[64, 128]}
									sizes="4rem"
									loading="lazy"
								/>
							) : (
								<div
									class="size-16 shrink-0 rounded-2xl ring ring-inset ring-white/15"
									style={`background:${getProjectGradient(project.data.title)}`}
									aria-hidden="true"
								/>
							)}
							<div class="min-w-0 flex-1">
								<div class="flex flex-wrap items-center gap-2">
									<span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-1 text-xs font-semibold text-primary ring ring-inset ring-primary/10">
										{project.data.category}
									</span>
									{
										project.data.location ? (
											<span class="text-sm font-medium text-muted-foreground">
												{project.data.location}
											</span>
										) : null
									}
								</div>
								<h3 class="mt-2 text-xl font-bold tracking-tight text-balance">
									{project.data.title}
								</h3>
								{
									project.data.website && websiteLabel ? (
										<a
											href={project.data.website}
											target="_blank"
											rel="noreferrer noopener"
											class="mt-1 block truncate text-sm font-medium text-link underline decoration-link-decoration underline-offset-4"
										>
											{websiteLabel}
										</a>
									) : null
								}
							</div>
						</div>

						<div class="mt-auto flex flex-wrap gap-2">
							<a
								href={detailHref}
								class="inline-flex items-center gap-2 rounded-2xl corner-squircle bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground no-underline transition hover:bg-primary/80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
							>
								<Icon name="mdi:arrow-right" class="size-4" aria-hidden="true" />
								Подробнее
							</a>
							{
								project.data.instagram ? (
									<a
										href={project.data.instagram}
										target="_blank"
										rel="noreferrer noopener"
										class="inline-flex items-center gap-2 rounded-2xl corner-squircle bg-transparent px-4 py-2 text-sm font-semibold text-primary/80 no-underline ring ring-inset ring-primary/10 transition hover:bg-primary/5 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
									>
										<Icon name="mdi:instagram" class="size-4" aria-hidden="true" />
										Instagram
									</a>
								) : null
							}
						</div>
					</article>
				))
			}
		</div>

		<p id="project-empty" class="hidden py-8 text-center text-sm text-muted-foreground">
			По выбранным категориям проектов пока нет.
		</p>
	</section>

	<script>
		const filter = document.getElementById("project-filter");
		const buttons = Array.from(
			document.querySelectorAll<HTMLButtonElement>(".filter-btn"),
		);
		const cards = Array.from(
			document.querySelectorAll<HTMLElement>(".project-card"),
		);
		const empty = document.getElementById("project-empty");
		const selected = new Set<string>();

		const activeOn = ["bg-primary", "text-primary-foreground", "ring-primary"];
		const activeOff = [
			"bg-surface",
			"text-muted-foreground",
			"ring-border-muted",
			"hover:bg-primary/5",
		];

		function setActive(button: HTMLButtonElement, active: boolean) {
			button.setAttribute("aria-pressed", String(active));
			button.classList.remove(...(active ? activeOff : activeOn));
			button.classList.add(...(active ? activeOn : activeOff));
		}

		function render() {
			for (const button of buttons) {
				const category = button.dataset.category ?? "";
				const active = category === "" ? selected.size === 0 : selected.has(category);
				setActive(button, active);
			}

			let visible = 0;
			for (const card of cards) {
				const category = card.dataset.category ?? "";
				const show = selected.size === 0 || selected.has(category);
				card.classList.toggle("hidden", !show);
				if (show) visible++;
			}

			empty?.classList.toggle("hidden", visible > 0);
		}

		filter?.addEventListener("click", (event) => {
			const button = (event.target as HTMLElement).closest<HTMLButtonElement>(".filter-btn");
			if (!button) return;

			const category = button.dataset.category ?? "";
			if (category === "") {
				selected.clear();
			} else if (selected.has(category)) {
				selected.delete(category);
			} else {
				selected.add(category);
			}

			render();
		});

		render();
	</script>
</Layout>
