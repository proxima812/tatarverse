---
import BackButton from "@/components/navigation/BackButton.astro";
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCollection, render, type CollectionEntry } from "astro:content";
import type { ImageMetadata } from "astro";

export async function getStaticPaths() {
	const projects = await getCollection("projects");

	return projects.map((project) => ({
		params: { id: project.id },
		props: { project },
	}));
}

interface Props {
	project: CollectionEntry<"projects">;
}

const { project } = Astro.props as Props;
const { Content } = await render(project);
const data = project.data;
const projectAssets = import.meta.glob<{ default: ImageMetadata }>(
	"../../assets/projects/**/*.{jpg,jpeg,png,webp}",
	{ eager: true },
);

function getProjectAsset(path: string) {
	const asset = projectAssets[`../../assets/projects/${path}`]?.default;

	if (!asset) {
		throw new Error(`Project asset not found: ${path}`);
	}

	return asset;
}

function getUrlLabel(url?: string) {
	if (!url) return null;

	try {
		return new URL(url).hostname.replace(/^www\./, "");
	} catch {
		return url;
	}
}

const logo = getProjectAsset(data.logo);
const image = getProjectAsset(data.image);
const websiteLabel = getUrlLabel(data.website);
---

<Layout
	title={`${data.title} | #поддержка`}
	description={data.description}
	keywords={["tatarverse", "поддержка", data.title, data.category, ...data.tags]}
>
	<BackButton href="/support" variant="outline" label="#поддержка" />
	<main class="mx-auto w-full max-w-4xl space-y-6">
		<header
			class="corner-squircle rounded-4xl bg-surface p-5 shadow-2xs ring ring-border-muted sm:p-6"
		>
			<div class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
				<div class="flex min-w-0 items-center gap-4">
					<Image
						src={logo}
						alt={`Логотип ${data.title}`}
						class="size-20 shrink-0 rounded-3xl bg-white object-contain p-1.5 ring ring-border-muted"
						widths={[80, 160]}
						sizes="5rem"
					/>
					<div class="min-w-0">
						<div class="flex flex-wrap items-center gap-2">
							<span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-1 text-xs font-semibold text-primary ring ring-inset ring-primary/10">
								{data.category}
							</span>
							{
								data.location ? (
									<span class="text-sm font-medium text-muted-foreground">{data.location}</span>
								) : null
							}
						</div>
						<h1 class="mt-2 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
							{data.title}
						</h1>
						{
							data.website && websiteLabel ? (
								<a
									href={data.website}
									target="_blank"
									rel="noreferrer noopener"
									class="mt-1 block truncate text-sm font-medium text-link underline decoration-link-decoration underline-offset-4"
								>
									{websiteLabel}
								</a>
							) : null
						}
					</div>
				</div>

				<div class="flex flex-wrap gap-2 sm:justify-end">
					{
						data.orderUrl ? (
							<a
								href={data.orderUrl}
								target="_blank"
								rel="noreferrer noopener"
								class="inline-flex items-center rounded-2xl corner-squircle bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground no-underline transition hover:bg-primary/80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
							>
								{data.orderLabel ?? "Заказать"}
							</a>
						) : null
					}
					{
						data.instagram ? (
							<a
								href={data.instagram}
								target="_blank"
								rel="noreferrer noopener"
								class="inline-flex items-center rounded-2xl corner-squircle bg-transparent px-4 py-2 text-sm font-semibold text-primary/80 no-underline ring ring-inset ring-primary/10 transition hover:bg-primary/5 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
							>
								Instagram
							</a>
						) : null
					}
				</div>
			</div>
		</header>

		<Image
			src={image}
			alt={`Фото проекта ${data.title}`}
			class="corner-squircle max-h-[34rem] w-full rounded-4xl object-cover shadow-2xs ring ring-border-muted"
			widths={[640, 960, 1280]}
			sizes="(min-width: 1024px) 56rem, 100vw"
		/>

		<section class="grid gap-5 lg:grid-cols-[minmax(0,1fr)_16rem]" aria-label="Описание проекта">
			<article
				class="corner-squircle rounded-4xl bg-surface p-5 shadow-2xs ring ring-border-muted sm:p-6"
			>
				<h2 class="text-xl font-bold tracking-tight text-foreground">Описание</h2>
				<p class="mt-3 text-sm leading-6 text-muted-foreground sm:text-base">
					{data.description}
				</p>
				<div
					class="prose prose-sm mt-5 max-w-none text-depth-600 sm:prose-base prose-p:my-2 prose-a:font-medium prose-a:text-link prose-a:decoration-link-decoration prose-a:underline-offset-4 first:prose-p:mt-0 last:prose-p:mb-0"
				>
					<Content />
				</div>
			</article>

			<aside
				class="corner-squircle h-fit rounded-4xl bg-surface p-5 shadow-2xs ring ring-border-muted sm:p-6"
			>
				<h2 class="text-sm font-bold uppercase tracking-wide text-muted-foreground">Теги</h2>
				<ul class="mt-4 flex flex-wrap gap-2" aria-label={`Теги ${data.title}`}>
					{
						data.tags.map((tag) => (
							<li class="rounded-full bg-muted px-3 py-1 text-xs font-medium text-muted-foreground ring ring-inset ring-border-muted">
								{tag}
							</li>
						))
					}
				</ul>
			</aside>
		</section>
	</main>
</Layout>
