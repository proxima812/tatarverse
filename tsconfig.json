{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "strictNullChecks": true,
    "baseUrl": ".",
    "paths": {
			"@/*": ["src/*"]
		},
    "exactOptionalPropertyTypes": false,
    "allowJs": true
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["node_modules", ".vercel", ".netlify", "dist"]
}
